@page "/ilanlarim"
@model AracParki.Web.Pages.Ilanlarim.IndexModel
@using AracParki.Application.Listings
@using AracParki.Domain.Listings
@{
    Layout = "Shared/_AccountLayout";
    var now = DateTimeOffset.Now;
    var activeStatus = Model.Status;
    string TabHref(string? status) => string.IsNullOrEmpty(status) ? "/ilanlarim" : $"/ilanlarim?durum={status}";
    string? TabCurrent(string? status) =>
        string.Equals(activeStatus, status, StringComparison.Ordinal) ? "page" : null;
    string? TabActive(string? status) =>
        string.Equals(activeStatus, status, StringComparison.Ordinal) ? "is-active" : null;
    var emptyCopy = activeStatus switch
    {
        ListingStatus.Published => "Yayında ilan yok.",
        ListingStatus.PendingReview => "İncelemede ilan yok.",
        ListingStatus.Rejected => "Reddedilmiş ilan yok.",
        ListingStatus.Archived => "Arşivde ilan yok.",
        _ => "Henüz ilanın yok."
    };
}
<header class="page-account-head">
  <partial name="Shared/Partials/_AccountBack" model='("/panel", "Panel")' />
  <div class="page-account-title-row">
    <div>
      <h1>İlanlarım</h1>
      <p class="page-account-lead">Yayındaki, arşivdeki ve incelemedeki ilanların</p>
    </div>
  </div>
</header>

@if (!string.IsNullOrWhiteSpace(Model.FormError))
{
  <p class="field-error" role="alert">@Model.FormError</p>
}

@if (Model.TotalCount > 0)
{
  <nav class="account-filter-tabs" aria-label="Durum filtresi">
    <a class="@TabActive(null)" href="@TabHref(null)" aria-current="@TabCurrent(null)">
      <span>Tümü</span>
      <span class="account-filter-count">@Model.TotalCount</span>
    </a>
    <a class="@TabActive(ListingStatus.Published)"
       href="@TabHref(ListingStatus.Published)"
       aria-current="@TabCurrent(ListingStatus.Published)">
      <span>Yayında</span>
      <span class="account-filter-count">@(Model.StatusCounts.GetValueOrDefault(ListingStatus.Published))</span>
    </a>
    <a class="@TabActive(ListingStatus.PendingReview)"
       href="@TabHref(ListingStatus.PendingReview)"
       aria-current="@TabCurrent(ListingStatus.PendingReview)">
      <span>İncelemede</span>
      <span class="account-filter-count">@(Model.StatusCounts.GetValueOrDefault(ListingStatus.PendingReview))</span>
    </a>
    <a class="@TabActive(ListingStatus.Rejected)"
       href="@TabHref(ListingStatus.Rejected)"
       aria-current="@TabCurrent(ListingStatus.Rejected)">
      <span>Reddedildi</span>
      <span class="account-filter-count">@(Model.StatusCounts.GetValueOrDefault(ListingStatus.Rejected))</span>
    </a>
    <a class="@TabActive(ListingStatus.Archived)"
       href="@TabHref(ListingStatus.Archived)"
       aria-current="@TabCurrent(ListingStatus.Archived)">
      <span>Arşiv</span>
      <span class="account-filter-count">@(Model.StatusCounts.GetValueOrDefault(ListingStatus.Archived))</span>
    </a>
  </nav>
}

@if (Model.Items.Count == 0)
{
  <div class="empty-state">
    <span class="empty-state-icon" aria-hidden="true"><ap-icon name="plus" size="22" class="ap-icon" /></span>
    <p>@emptyCopy</p>
    @if (Model.TotalCount == 0)
    {
      <div class="empty-state-actions">
        <a class="btn btn-machine" href="/ilan-ver">Ücretsiz İlan Ver</a>
      </div>
    }
  </div>
}
else
{
  <div class="admin-listing-list">
    @foreach (var item in Model.Items)
    {
      var canEdit = ListingStatus.IsOwnerEditable(item.Status);
      var isPublished = item.Status == ListingStatus.Published;
      var isArchived = item.Status == ListingStatus.Archived;
      var isPending = item.Status == ListingStatus.PendingReview;
      var isRejected = item.Status == ListingStatus.Rejected;
      var hasRejectReason = isRejected && !string.IsNullOrWhiteSpace(item.RejectionReason);
      var detailHref = ListingRoutes.Detail(item.AdNo);
      var editHref = $"/ilan-ver?duzenle={item.AdNo}";
      var expiresSoon = isPublished && item.ExpiresAt is DateTimeOffset exp
          && exp > now && exp <= now.AddDays(7);
      var expiresPast = isPublished && item.ExpiresAt is DateTimeOffset past && past <= now;
      var thumb = ListingImageUrlVariants.WithVariant(item.CoverImageUrl, ListingImageVariants.Thumb);

      <article class="admin-listing-row">
        <a class="admin-listing-thumb img-shell is-loading" href="@detailHref">
          <img src="@thumb" alt="" width="120" height="90" loading="lazy" decoding="async" />
        </a>
        <div class="admin-listing-body">
          <h2><a href="@detailHref">@item.Title</a></h2>
          <div class="admin-listing-meta">
            <span class="@ListingStatus.BadgeClass(item.Status)">@ListingStatus.Label(item.Status)</span>
            @if (hasRejectReason)
            {
              <span class="account-reject-pop"
                    x-data="accountPopover"
                    @@keydown.escape.window="close"
                    @@click.outside="close">
                <button type="button"
                        class="account-reject-pop-trigger"
                        @@click="toggle"
                        :aria-expanded="openAria"
                        aria-haspopup="dialog"
                        aria-label="Red nedenini göster">
                  <ap-icon name="circle-alert" size="14" class="ap-icon" aria-hidden="true" />
                </button>
                <div class="account-reject-pop-panel"
                     role="dialog"
                     aria-label="Red nedeni"
                     x-show="open"
                     x-cloak
                     x-transition.opacity.duration.120ms>
                  <strong>Red nedeni</strong>
                  <p>@item.RejectionReason</p>
                </div>
              </span>
            }
            <span>· @item.AdNo · @item.City@(string.IsNullOrWhiteSpace(item.District) ? "" : $" / {item.District}")</span>
            @if (isPublished && item.ExpiresAt is DateTimeOffset expiresAt)
            {
              <span class="@(expiresPast ? "account-expiry is-past" : expiresSoon ? "account-expiry is-soon" : "account-expiry")">
                · @(expiresPast ? "Süresi doldu" : $"Bitiş {expiresAt.ToLocalTime():dd.MM.yyyy}")
              </span>
            }
          </div>
        </div>
        @if (canEdit || isPublished || isArchived || isPending || isRejected)
        {
          <div class="account-listing-actions"
               x-data="accountPopover"
               @@keydown.escape.window="close"
               @@click.outside="close">
            <button type="button"
                    class="btn btn-ghost btn-sm account-action-trigger"
                    @@click="toggle"
                    :aria-expanded="openAria"
                    aria-haspopup="menu">
              <span>İşlemler</span>
              <ap-icon name="chevron-down" size="14" class="ap-icon" aria-hidden="true" />
            </button>
            <div class="account-action-menu"
                 role="menu"
                 aria-label="İlan işlemleri"
                 x-show="open"
                 x-cloak
                 x-transition.opacity.duration.120ms>
              @if (canEdit)
              {
                <a class="account-action-item" role="menuitem" href="@editHref" @@click="close">
                  <ap-icon name="settings" size="14" class="ap-icon" aria-hidden="true" />
                  <span>@(isPublished ? "Düzenle" : isArchived ? "Düzenle" : "Düzenle ve tekrar gönder")</span>
                </a>
              }
              <a class="account-action-item" role="menuitem" href="@detailHref" @@click="close">
                <ap-icon name="eye" size="14" class="ap-icon" aria-hidden="true" />
                <span>@(isPublished ? "İlanı görüntüle" : "Önizleme")</span>
              </a>
              @if (isPublished)
              {
                <form method="post" asp-page-handler="Archive" role="none">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="adNo" value="@item.AdNo" />
                  @if (!string.IsNullOrEmpty(Model.Status))
                  {
                    <input type="hidden" name="durum" value="@Model.Status" />
                  }
                  <button type="submit"
                          class="account-action-item account-action-item--danger"
                          role="menuitem"
                          @@click="close"
                          onclick="return confirm('İlan yayından kaldırılsın mı? Daha sonra yeniden yayınlayabilirsin.');">
                    <ap-icon name="eye-off" size="14" class="ap-icon" aria-hidden="true" />
                    <span>Yayından kaldır</span>
                  </button>
                </form>
              }
              @if (isArchived)
              {
                <form method="post" asp-page-handler="Republish" role="none">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="adNo" value="@item.AdNo" />
                  @if (!string.IsNullOrEmpty(Model.Status))
                  {
                    <input type="hidden" name="durum" value="@Model.Status" />
                  }
                  <button type="submit" class="account-action-item" role="menuitem" @@click="close">
                    <ap-icon name="refresh-cw" size="14" class="ap-icon" aria-hidden="true" />
                    <span>Yeniden yayınla</span>
                  </button>
                </form>
              }
            </div>
          </div>
        }
      </article>
    }
  </div>
}
