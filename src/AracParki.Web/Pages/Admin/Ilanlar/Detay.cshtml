@page "/admin/ilanlar/{adNo}"
@model AracParki.Web.Pages.Admin.Ilanlar.DetayModel
@{
    Layout = "Shared/_AccountLayout";
    var listing = Model.Listing!;
    var images = listing.ImageUrls.Count > 0
        ? listing.ImageUrls
        : string.IsNullOrWhiteSpace(listing.CoverImageUrl)
            ? Array.Empty<string>()
            : new[] { listing.CoverImageUrl };
    var mainImage = images.Count > 0 ? images[0] : ListingImageUrl.Placeholder;
    var mainDisplay = ListingImageUrlVariants.WithVariant(mainImage, ListingImageVariants.Lg);
    var mainSrcSet = ListingImageUrlVariants.SrcSet(
        mainImage,
        (ListingImageVariants.Md, 768),
        (ListingImageVariants.Lg, 1280),
        (ListingImageVariants.Xl, 1920));
    var locationText = $"{listing.City} / {listing.District}" +
        (string.IsNullOrWhiteSpace(listing.Neighborhood) ? "" : $" / {listing.Neighborhood}");
    var isCorporate = listing.CorporateAccountId is > 0;
    var sellerLabel = isCorporate
        ? "Bayi"
        : SellerType.Label(listing.SellerType);
    // Kurumsal ilanda mağaza adı (ca.display_name); kişisel satıcıda hesap görünen adı.
    var sellerDisplay = !string.IsNullOrWhiteSpace(listing.CorporateDisplayName)
        ? listing.CorporateDisplayName!
        : listing.SellerName;
    var sellerFieldLabel = isCorporate ? "Mağaza adı" : "Satıcı adı";
    var priceText = Formatters.Price(
        listing.Price,
        listing.PrimaryIntent == ListingIntent.Kiralik ? listing.PriceUnit : null,
        listing.Currency);
    var isPending = listing.Status == ListingStatus.PendingReview;
    var isRejected = listing.Status == ListingStatus.Rejected;
    var isPublished = listing.Status == ListingStatus.Published;
    ViewData["NeedDetailGallery"] = true;
}
<header class="page-account-head admin-mod-head">
  <partial name="Shared/Partials/_AccountBack"
           model='($"/admin/ilanlar?durum={listing.Status}", "İlanlar")' />
  <div class="admin-mod-hero">
    <div class="admin-mod-hero-text">
      <div class="admin-corp-title-row">
        <h1>@listing.Title</h1>
        <span class="@ListingStatus.BadgeClass(listing.Status)">@ListingStatus.Label(listing.Status)</span>
      </div>
      <p class="admin-mod-price">@priceText</p>
      <p class="admin-mod-meta">
        <ap-icon name="map-pin" size="14" />
        <span>@locationText</span>
        <span class="admin-corp-sep">·</span>
        <span>@sellerDisplay</span>
        <span class="admin-corp-sep">·</span>
        <span>@sellerLabel</span>
        @if (listing.SubmittedAt is not null)
        {
          <span class="admin-corp-sep">·</span>
          <span>Başvuru @listing.SubmittedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
        }
      </p>
      <ul class="admin-mod-chips" aria-label="İlan etiketleri">
        <li class="@(listing.PrimaryIntent == ListingIntent.Kiralik ? "is-rent" : "is-sale")">@ListingIntent.Label(listing.PrimaryIntent)</li>
        <li>@EquipmentCondition.Label(listing.Condition)</li>
        <li>@listing.Category</li>
      </ul>
    </div>
  </div>
</header>

@if (!string.IsNullOrWhiteSpace(Model.FormError))
{
  <p class="field-error" role="alert">@Model.FormError</p>
}

@if (isRejected && !string.IsNullOrWhiteSpace(listing.RejectionReason))
{
  <div class="admin-mod-banner is-rejected" role="status">
    <strong>Red nedeni</strong>
    <span>@listing.RejectionReason</span>
  </div>
}

<div class="admin-mod-grid">
  <div class="admin-mod-main">
    <section class="admin-mod-gallery-host" aria-label="İlan görselleri">
      @if (images.Count > 0)
      {
        var thumbsPerPage = 10;
        var thumbPageCount = Math.Max(1, (int)Math.Ceiling(images.Count / (double)thumbsPerPage));
        <div class="detail-gallery" data-detail-gallery data-thumbs-per-page="10" tabindex="0" aria-label="İlan görselleri">
          <div class="gallery-main-wrap">
            <img class="gallery-main"
                 src="@mainDisplay"
                 srcset="@mainSrcSet"
                 sizes="(max-width:900px) 100vw, 640px"
                 alt="@listing.Title"
                 width="900"
                 height="900"
                 loading="eager"
                 decoding="async"
                 data-gallery-main
                 data-gallery-src="@mainDisplay" />
            @if (images.Count > 1)
            {
              <button type="button" class="gallery-hit gallery-hit--prev" data-gallery-prev aria-label="Önceki görsel"></button>
              <button type="button" class="gallery-hit gallery-hit--next" data-gallery-next aria-label="Sonraki görsel"></button>
            }
            <button type="button" class="sr-only" data-gallery-lg-trigger id="gallery-lg-admin-@listing.Id" tabindex="-1">Galeri</button>
          </div>

          <div class="gallery-toolbar">
            <button type="button"
                    class="gallery-tool"
                    data-gallery-open
                    aria-haspopup="dialog">
              <ap-icon name="search" size="16" class="ap-icon" aria-hidden="true" />
              <span>Büyük Fotoğraf</span>
            </button>
          </div>

          <div class="gallery-thumbs-viewport">
            <div class="gallery-thumbs-track" data-gallery-track>
              @for (var pageIdx = 0; pageIdx < thumbPageCount; pageIdx++)
              {
                <div class="gallery-thumbs-page" role="list">
                  @for (var i = pageIdx * thumbsPerPage; i < Math.Min(images.Count, (pageIdx + 1) * thumbsPerPage); i++)
                  {
                    <button type="button"
                            role="listitem"
                            class="@(i == 0 ? "is-active" : null)"
                            data-gallery-thumb
                            data-src="@ListingImageUrlVariants.WithVariant(images[i], ListingImageVariants.Lg)"
                            data-srcset="@ListingImageUrlVariants.SrcSet(
                                images[i],
                                (ListingImageVariants.Md, 768),
                                (ListingImageVariants.Lg, 1280),
                                (ListingImageVariants.Xl, 1920))"
                            data-index="@i"
                            aria-label="Görsel @(i + 1)"
                            aria-current="@(i == 0 ? "true" : "false")">
                      <img src="@ListingImageUrlVariants.WithVariant(images[i], ListingImageVariants.Thumb)"
                           alt="@(listing.Title) — görsel @(i + 1)"
                           width="88"
                           height="88"
                           loading="lazy"
                           decoding="async" />
                    </button>
                  }
                </div>
              }
            </div>
          </div>

          <div class="gallery-footer">
            <span class="gallery-counter" data-gallery-counter>1/@images.Count Fotoğraf</span>
            @if (thumbPageCount > 1)
            {
              <div class="gallery-pager" data-gallery-pager>
                <button type="button" class="gallery-page-btn" data-gallery-page-prev aria-label="Önceki fotoğraf grubu">
                  <ap-icon name="arrow-left" size="16" class="ap-icon" aria-hidden="true" />
                </button>
                <div class="gallery-dots" data-gallery-dots role="tablist" aria-label="Fotoğraf grupları">
                  @for (var pageIdx = 0; pageIdx < thumbPageCount; pageIdx++)
                  {
                    <button type="button"
                            class="gallery-dot @(pageIdx == 0 ? "is-active" : null)"
                            data-gallery-page="@pageIdx"
                            aria-label="Grup @(pageIdx + 1)"
                            aria-selected="@(pageIdx == 0 ? "true" : "false")"></button>
                  }
                </div>
                <button type="button" class="gallery-page-btn" data-gallery-page-next aria-label="Sonraki fotoğraf grubu">
                  <ap-icon name="arrow-right" size="16" class="ap-icon" aria-hidden="true" />
                </button>
              </div>
            }
          </div>
        </div>
      }
      else
      {
        <div class="admin-mod-gallery-empty" role="img" aria-label="Fotoğraf yok">
          <img src="@ListingImageUrl.Placeholder" alt="" width="120" height="120" />
          <span>Fotoğraf yok</span>
        </div>
      }
    </section>

    <section class="admin-corp-panel">
      <h2 class="admin-corp-panel-title">Makine</h2>
      <dl class="admin-corp-dl">
        <div><dt>Kategori</dt><dd>@listing.Category</dd></div>
        <div><dt>Marka / model</dt><dd>@listing.Brand @listing.ModelName</dd></div>
        <div><dt>Yıl</dt><dd>@listing.ModelYear</dd></div>
        <div><dt>Çalışma saati</dt><dd>@(listing.Hours is null ? "—" : Formatters.Hours(listing.Hours.Value))</dd></div>
        <div><dt>Tonaj</dt><dd>@Formatters.Tons(listing.Tons)</dd></div>
        <div><dt>Kapasite</dt><dd>@(listing.CapacityKg is null ? "—" : $"{listing.CapacityKg:N0} kg")</dd></div>
        <div><dt>Beygir</dt><dd>@(listing.Horsepower is null ? "—" : $"{listing.Horsepower} HP")</dd></div>
        <div><dt>Seri no</dt><dd class="admin-corp-mono">@(string.IsNullOrWhiteSpace(listing.SerialNo) ? "—" : listing.SerialNo)</dd></div>
      </dl>
    </section>

    <section class="admin-corp-panel">
      <h2 class="admin-corp-panel-title">Satış bilgisi</h2>
      <dl class="admin-corp-dl">
        <div><dt>Fiyat</dt><dd><strong>@priceText</strong></dd></div>
        @if (listing.RentPrice is not null)
        {
          <div><dt>Kira fiyatı</dt><dd>@Formatters.Price(listing.RentPrice.Value, listing.PriceUnit, listing.Currency)</dd></div>
        }
        <div><dt>Amaç</dt><dd>@ListingIntent.Label(listing.PrimaryIntent)</dd></div>
        <div><dt>Durum</dt><dd>@EquipmentCondition.Label(listing.Condition)</dd></div>
        <div><dt>Operatör</dt><dd>@(listing.IncludesOperator ? "Dahil" : "Yok")</dd></div>
        <div><dt>Konum</dt><dd>@locationText</dd></div>
        <div><dt>İlan no</dt><dd class="admin-corp-mono">@listing.AdNo</dd></div>
        <div><dt>Yayın tarihi</dt><dd>@listing.ListedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd></div>
      </dl>
    </section>

    <section class="admin-corp-panel">
      <h2 class="admin-corp-panel-title">Satıcı</h2>
      <dl class="admin-corp-dl">
        <div><dt>@sellerFieldLabel</dt><dd>@sellerDisplay</dd></div>
        <div><dt>Tür</dt><dd>@sellerLabel</dd></div>
        <div><dt>Doğrulama</dt><dd>@(listing.IsVerified ? "Doğrulanmış" : "—")</dd></div>
        @if (listing.CorporateAccountId is > 0)
        {
          <div>
            <dt>Kurumsal hesap</dt>
            <dd>
              <a href="/admin/kurumsal/@listing.CorporateAccountId">#@listing.CorporateAccountId incele</a>
            </dd>
          </div>
        }
        @if (listing.OwnerAccountId is > 0)
        {
          <div><dt>Hesap ID</dt><dd class="admin-corp-mono">@listing.OwnerAccountId</dd></div>
        }
      </dl>
    </section>

    @if (listing.Attachments.Count > 0)
    {
      <section class="admin-corp-panel">
        <h2 class="admin-corp-panel-title">Donanım / ekler</h2>
        <ul class="admin-mod-attachments">
          @foreach (var att in listing.Attachments)
          {
            <li>@att.Name</li>
          }
        </ul>
      </section>
    }

    <section class="admin-corp-panel">
      <h2 class="admin-corp-panel-title">Açıklama</h2>
      <div class="admin-mod-desc detail-desc">@Html.Raw(ListingDescriptionHtml.ToSafeDisplayHtml(listing.Description))</div>
    </section>
  </div>

  <aside class="admin-mod-aside">
    <section class="admin-corp-panel admin-corp-aside-card">
      <h2 class="admin-corp-panel-title">Özet</h2>
      <dl class="admin-mod-aside-dl">
        <div><dt>Durum</dt><dd><span class="@ListingStatus.BadgeClass(listing.Status)">@ListingStatus.Label(listing.Status)</span></dd></div>
        <div><dt>İlan no</dt><dd class="admin-corp-mono">@listing.AdNo</dd></div>
        <div><dt>Fotoğraf</dt><dd>@images.Count</dd></div>
        <div><dt>Fiyat</dt><dd>@priceText</dd></div>
      </dl>
      <a class="btn btn-ghost btn-block admin-mod-preview-link" href="/ilan/@listing.AdNo" target="_blank" rel="noopener noreferrer">
        Önizleme aç
        <ap-icon name="external-link" size="14" />
      </a>
    </section>

    @if (isPending)
    {
      <section class="admin-corp-panel admin-corp-aside-card admin-corp-actions">
        <h2 class="admin-corp-panel-title">Karar</h2>
        <p class="admin-corp-muted admin-corp-actions-lead">
          Görselleri, fiyatı ve açıklamayı kontrol ettikten sonra onayla veya gerekçeli reddet.
        </p>
        <form method="post" asp-page-handler="Approve">
          @Html.AntiForgeryToken()
          <button class="btn btn-machine btn-block" type="submit">Onayla ve yayınla</button>
        </form>
        <form method="post" asp-page-handler="Reject" class="admin-corp-reject-form">
          @Html.AntiForgeryToken()
          <label class="ap-label" for="reason">Red nedeni <abbr class="field-req" title="Zorunlu">*</abbr></label>
          <textarea class="ap-input corp-textarea" id="reason" name="reason" required rows="4" maxlength="1000"
                    placeholder="Kullanıcıya gösterilecek net gerekçe…"></textarea>
          <button class="btn btn-dark btn-block" type="submit">Reddet</button>
        </form>
      </section>
    }
    else if (isRejected)
    {
      <section class="admin-corp-panel admin-corp-aside-card admin-corp-aside-reject">
        <h2 class="admin-corp-panel-title">Reddedildi</h2>
        <p>@(string.IsNullOrWhiteSpace(listing.RejectionReason) ? "—" : listing.RejectionReason)</p>
        <p class="admin-corp-muted">Satıcı düzenleyip yeniden gönderebilir.</p>
      </section>
    }
    else if (isPublished)
    {
      <section class="admin-corp-panel admin-corp-aside-card admin-corp-aside-ok">
        <h2 class="admin-corp-panel-title">Yayında</h2>
        <p>Bu ilan herkese açık listede görünür.</p>
        @if (listing.ExpiresAt is DateTimeOffset expiresAt)
        {
          <p class="admin-corp-muted">Yayın bitişi: @expiresAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
        }
        <a class="btn btn-machine btn-block" href="/ilan/@listing.AdNo" target="_blank" rel="noopener noreferrer">
          Canlı sayfayı aç
        </a>
        <form method="post" asp-page-handler="Archive" class="admin-mod-archive-form">
          @Html.AntiForgeryToken()
          <button class="btn btn-ghost btn-block" type="submit"
                  onclick="return confirm('İlan yayından kaldırılsın mı? Satıcı daha sonra yeniden yayınlayabilir.');">
            Yayından kaldır
          </button>
        </form>
      </section>
    }
    else if (listing.Status == ListingStatus.Archived)
    {
      <section class="admin-corp-panel admin-corp-aside-card">
        <h2 class="admin-corp-panel-title">Arşiv</h2>
        <p class="admin-corp-muted">İlan yayında değil. Satıcı yeniden yayınlayabilir.</p>
      </section>
    }
  </aside>
</div>

@section Scripts {
  <script src="~/lib/lightgallery/lightgallery.umd.js" asp-append-version="true" defer></script>
  <script src="~/lib/lightgallery/plugins/lg-thumbnail.umd.js" asp-append-version="true" defer></script>
  <script src="~/lib/lightgallery/plugins/lg-zoom.umd.js" asp-append-version="true" defer></script>
}
