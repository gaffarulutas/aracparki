@page "/admin/kurumsal"
@model AracParki.Web.Pages.Admin.Kurumsal.IndexModel
@using AracParki.Domain.Corporate
@{
    Layout = "Shared/_AccountLayout";
    var emptyCopy = Model.Status switch
    {
        CorporateStatus.Approved => "Onaylı kurumsal hesap yok.",
        CorporateStatus.Rejected => "Reddedilmiş başvuru yok.",
        _ => "Onay bekleyen başvuru yok."
    };
}
<header class="page-account-head">
  <nav class="page-account-kicker" aria-label="Breadcrumb">
    <a class="link-quiet" href="/admin">Admin</a>
    <span class="account-kicker-sep" aria-hidden="true">/</span>
    <span aria-current="page">Kurumsal hesaplar</span>
  </nav>
  <div class="page-account-title-row">
    <div>
      <h1>Kurumsal moderasyon</h1>
      <p class="page-account-lead">Bayi ve galeri başvurularını incele, onayla veya reddet.</p>
    </div>
  </div>
</header>

<nav class="account-filter-tabs" aria-label="Durum filtresi">
  <a class="@(Model.Status == CorporateStatus.Pending ? "is-active" : null)"
     href="/admin/kurumsal?durum=@CorporateStatus.Pending"
     aria-current="@(Model.Status == CorporateStatus.Pending ? "page" : null)">
    <span>Onay bekliyor</span>
    <span class="account-filter-count">@Model.Counts.Pending</span>
  </a>
  <a class="@(Model.Status == CorporateStatus.Approved ? "is-active" : null)"
     href="/admin/kurumsal?durum=@CorporateStatus.Approved"
     aria-current="@(Model.Status == CorporateStatus.Approved ? "page" : null)">
    <span>Onaylı</span>
    <span class="account-filter-count">@Model.Counts.Approved</span>
  </a>
  <a class="@(Model.Status == CorporateStatus.Rejected ? "is-active" : null)"
     href="/admin/kurumsal?durum=@CorporateStatus.Rejected"
     aria-current="@(Model.Status == CorporateStatus.Rejected ? "page" : null)">
    <span>Reddedilen</span>
    <span class="account-filter-count">@Model.Counts.Rejected</span>
  </a>
</nav>

@if (Model.Items.Count == 0)
{
  <div class="empty-state">
    <span class="empty-state-icon" aria-hidden="true"><ap-icon name="building-2" size="22" class="ap-icon" /></span>
    <p>@emptyCopy</p>
  </div>
}
else
{
  <div class="admin-corp-list">
    @foreach (var item in Model.Items)
    {
      var initial = string.IsNullOrWhiteSpace(item.DisplayName)
          ? "?"
          : char.ToUpperInvariant(item.DisplayName.Trim()[0]).ToString();
      <article class="admin-corp-row">
        <div class="admin-corp-avatar" aria-hidden="true">@initial</div>
        <div class="admin-corp-body">
          <div class="admin-corp-title-row">
            <h2 class="admin-corp-title">
              <a href="/admin/kurumsal/@item.Id">@item.DisplayName</a>
            </h2>
            <span class="@CorporateStatus.BadgeClass(item.Status)">@CorporateStatus.Label(item.Status)</span>
          </div>
          <p class="admin-corp-trade">@item.TradeName</p>
          <ul class="admin-corp-chips">
            <li>@CompanyType.Label(item.CompanyType)</li>
            <li>@item.CityName / @item.DistrictName</li>
            <li>VKN/TCKN @item.TaxNumber</li>
          </ul>
          <p class="admin-corp-owner">
            <ap-icon name="circle-user" size="14" />
            <span>@(item.OwnerName)</span>
            <span class="admin-corp-sep">·</span>
            <span>@item.OwnerEmail</span>
            @if (item.SubmittedAt is not null)
            {
              <span class="admin-corp-sep">·</span>
              <time datetime="@item.SubmittedAt.Value.ToString("o")">
                @item.SubmittedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
              </time>
            }
          </p>
          @if (!string.IsNullOrWhiteSpace(item.RejectionReason))
          {
            <p class="admin-corp-reject">@item.RejectionReason</p>
          }
        </div>
        <a class="btn btn-machine btn-sm admin-corp-cta" href="/admin/kurumsal/@item.Id">
          @(item.Status == CorporateStatus.Pending ? "İncele" : "Görüntüle")
        </a>
      </article>
    }
  </div>
}
