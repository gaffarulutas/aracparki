@page "/admin/sikayetler/{id:long}"
@model AracParki.Web.Pages.Admin.Sikayetler.DetayModel
@using AracParki.Domain.Listings
@{
    Layout = "Shared/_AccountLayout";
    var report = Model.Report!;
    var cover = string.IsNullOrWhiteSpace(report.CoverImageUrl)
        ? "/assets/logo/icon-512.png"
        : report.CoverImageUrl;
    var isActive = ListingReportStatus.IsActive(report.Status);
    var canArchive = isActive && report.ListingStatus == ListingStatus.Published;
}
<header class="page-account-head admin-corp-detail-head">
  <partial name="Shared/Partials/_AccountBack"
           model='($"/admin/sikayetler?durum={report.Status}", "Şikayetler")' />
  <div class="admin-corp-detail-hero">
    <div>
      <div class="admin-corp-title-row">
        <h1>Şikayet #@report.Id</h1>
        <span class="@ListingReportStatus.BadgeClass(report.Status)">@ListingReportStatus.Label(report.Status)</span>
      </div>
      <p class="admin-corp-trade">
        <span class="admin-corp-mono">@report.AdNo</span>
        <span class="admin-corp-sep">·</span>
        @report.ListingTitle
      </p>
    </div>
  </div>
</header>

@if (!string.IsNullOrWhiteSpace(Model.FormError))
{
  <p class="field-error" role="alert">@Model.FormError</p>
}

<div class="admin-corp-detail-grid">
  <div class="admin-corp-detail-main">
    <section class="admin-corp-panel">
      <h2 class="admin-corp-panel-title">Şikayet bilgisi</h2>
      <dl class="admin-corp-dl">
        <div>
          <dt>Neden</dt>
          <dd>@ListingReportReason.Label(report.ReasonCode)</dd>
        </div>
        <div>
          <dt>Tarih</dt>
          <dd>@report.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
        </div>
        <div class="admin-corp-dl-wide">
          <dt>Açıklama</dt>
          <dd>@(string.IsNullOrWhiteSpace(report.Message) ? "—" : report.Message)</dd>
        </div>
        <div>
          <dt>Şikayet eden</dt>
          <dd>@report.ReporterName</dd>
        </div>
        <div>
          <dt>E-posta</dt>
          <dd>@report.ReporterEmail</dd>
        </div>
        @if (!string.IsNullOrWhiteSpace(report.AdminNotes))
        {
          <div class="admin-corp-dl-wide">
            <dt>Admin notu</dt>
            <dd>@report.AdminNotes</dd>
          </div>
        }
        @if (report.ReviewedAt is not null)
        {
          <div>
            <dt>Son işlem</dt>
            <dd>@report.ReviewedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
          </div>
        }
      </dl>
    </section>

    <section class="admin-corp-panel">
      <h2 class="admin-corp-panel-title">İlan</h2>
      <article class="admin-listing-row admin-report-listing">
        <a class="admin-listing-thumb" href="/admin/ilanlar/@report.AdNo">
          <img src="@cover" alt="" width="120" height="90" loading="lazy" decoding="async" />
        </a>
        <div class="admin-listing-body">
          <h2><a href="/admin/ilanlar/@report.AdNo">@report.ListingTitle</a></h2>
          <div class="admin-listing-meta">
            <span class="@ListingStatus.BadgeClass(report.ListingStatus)">@ListingStatus.Label(report.ListingStatus)</span>
            <span class="admin-corp-sep">·</span>
            <span class="admin-corp-mono">@report.AdNo</span>
          </div>
        </div>
        <div class="admin-report-listing-actions">
          <a class="btn btn-ghost btn-sm" href="/admin/ilanlar/@report.AdNo">Moderasyon</a>
          <a class="btn btn-ghost btn-sm" href="/ilan/@report.AdNo" target="_blank" rel="noopener noreferrer">İlanı gör</a>
        </div>
      </article>
    </section>
  </div>

  <aside class="admin-corp-aside">
    @if (isActive)
    {
      <section class="admin-corp-panel admin-corp-aside-card admin-corp-actions">
        <h2 class="admin-corp-panel-title">Karar</h2>
        <p class="admin-corp-muted admin-corp-actions-lead">
          Sonuçlandırdığınızda şikayet eden kullanıcıya bildirim gider.
        </p>
        <form method="post"
              asp-page-handler="Resolve"
              class="admin-corp-reject-form admin-report-decision-form"
              data-archive-confirm="İlan yayından kaldırılsın ve şikayet sonuçlandırılsın mı?">
          @Html.AntiForgeryToken()
          <label class="ap-label" for="decision">Karar <abbr class="field-req" title="Zorunlu">*</abbr></label>
          <select class="ap-input" id="decision" name="decision" required>
            <option value="">Karar seçin…</option>
            @if (report.Status == ListingReportStatus.Open)
            {
              <option value="reviewing">İncelemeye al</option>
            }
            <option value="actioned">İşlem yapıldı</option>
            <option value="dismissed">İşlem yapılmadı</option>
            @if (canArchive)
            {
              <option value="archive">İlanı arşivle ve sonuçlandır</option>
            }
          </select>
          <label class="ap-label" for="adminNotes">Admin notu <span class="ap-optional">(opsiyonel)</span></label>
          <textarea class="ap-input corp-textarea"
                    id="adminNotes"
                    name="adminNotes"
                    rows="4"
                    maxlength="1000"
                    placeholder="Karar gerekçesi veya inceleme notu…"></textarea>
          <button class="btn btn-machine btn-block" type="submit">Kararı uygula</button>
        </form>
      </section>
    }
    else if (report.Status == ListingReportStatus.Actioned)
    {
      <section class="admin-corp-panel admin-corp-aside-card admin-corp-aside-ok">
        <h2 class="admin-corp-panel-title">İşlem yapıldı</h2>
        <p>Bu şikayet sonuçlandırıldı. Kullanıcıya bildirim gönderildi.</p>
        @if (report.ReviewedAt is not null)
        {
          <p class="admin-corp-muted">@report.ReviewedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
        }
      </section>
    }
    else
    {
      <section class="admin-corp-panel admin-corp-aside-card">
        <h2 class="admin-corp-panel-title">İşlem yapılmadı</h2>
        <p class="admin-corp-muted">Bu şikayet sonuçlandırıldı. Kullanıcıya bildirim gönderildi.</p>
        @if (report.ReviewedAt is not null)
        {
          <p class="admin-corp-muted">@report.ReviewedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
        }
      </section>
    }
  </aside>
</div>

@if (isActive)
{
  <script>
    (() => {
      const form = document.querySelector('.admin-report-decision-form');
      if (!form) return;
      form.addEventListener('submit', (e) => {
        const decision = form.querySelector('#decision');
        if (decision?.value === 'archive') {
          const msg = form.getAttribute('data-archive-confirm') || 'Onaylıyor musunuz?';
          if (!window.confirm(msg)) e.preventDefault();
        }
      });
    })();
  </script>
}
