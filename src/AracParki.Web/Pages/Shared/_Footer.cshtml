@using AracParki.Application.Site.Dtos
@model SiteSettingsDto
@{
    var site = Model;
    var year = DateTime.UtcNow.Year;
    var brand = string.IsNullOrWhiteSpace(site.CompanyDisplayName) ? "Araç Parkı" : site.CompanyDisplayName;
    var tagline = string.IsNullOrWhiteSpace(site.FooterTagline)
        ? "Türkiye genelinde satılık, kiralık ve ikinci el iş makineleri için uzman ilan platformu."
        : site.FooterTagline;
}
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid footer-grid--5">
      <div class="footer-brand">
        <a class="logo" href="/" aria-label="@brand">
          <span class="logo-arac">Araç</span><span class="logo-parki">Parkı</span>
        </a>
        <p>@tagline</p>
        @if (site.HasAnySocial)
        {
          <ul class="footer-social" aria-label="Sosyal medya">
            @foreach (var link in site.SocialLinks)
            {
              <li>
                <a href="@link.Url" target="_blank" rel="noopener noreferrer" aria-label="@link.Label" title="@link.Label">
                  <ap-icon name="@link.Icon" size="16" class="ap-icon" aria-hidden="true" />
                </a>
              </li>
            }
          </ul>
        }
      </div>
      <div class="footer-col">
        <h3>Keşfet</h3>
        <ul>
          <li><a href="/ilanlar?tip=satilik">Satılık iş makineleri</a></li>
          <li><a href="/ilanlar?tip=kiralik">Kiralık iş makineleri</a></li>
          <li><a href="/ilanlar?durum=used">İkinci el</a></li>
          <li><a href="/ilanlar">Tüm ilanlar</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>Kurumsal</h3>
        <ul>
          <li><a href="/hakkimizda">Hakkımızda</a></li>
          <li><a href="/iletisim">İletişim</a></li>
          <li><a href="/reklam">Reklam ver</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>Yardım</h3>
        <ul>
          <li><a href="/yardim">Yardım merkezi</a></li>
          <li><a href="/yardim/ilan-ver">Nasıl ilan verilir?</a></li>
          <li><a href="/guvenli-alisveris">Güvenli alışveriş</a></li>
          <li><a href="/ilan-kurallari">İlan kuralları</a></li>
          <li><a href="/ilan-ver">Ücretsiz ilan ver</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>Yasal</h3>
        <ul>
          <li><a href="/kullanim-kosullari">Kullanım koşulları</a></li>
          <li><a href="/gizlilik">Gizlilik bildirimi</a></li>
          <li><a href="/kvkk">KVKK aydınlatma metni</a></li>
          <li><a href="/cerez-politikasi">Çerez politikası</a></li>
        </ul>
      </div>
    </div>

    <p class="footer-disclaimer">
      @brand, satılık ve kiralık iş makineleri için bir ilan platformudur.
      İlanlardaki fiyat, özellik, durum ve diğer bilgilerden ilan sahipleri sorumludur;
      platform bu içeriklerin doğruluğunu veya güncelliğini garanti etmez.
      Alım-satım veya kiralama öncesi satıcıyla iletişime geçmenizi ve makineyi
      yerinde kontrol etmenizi öneririz.
    </p>

    <div class="footer-bottom">
      <span>© @year @brand · aracparki.com</span>
      <nav aria-label="Yasal kısayollar">
        <a href="/kullanim-kosullari" title="Kullanım koşulları">Kullanım koşulları</a>
        <a href="/gizlilik" title="Gizlilik bildirimi">Gizlilik</a>
        <a href="/kvkk" title="KVKK aydınlatma metni">KVKK</a>
        <a href="/cerez-politikasi" title="Çerez politikası">Çerez politikası</a>
        <a href="/iletisim" title="İletişim">İletişim</a>
      </nav>
    </div>
  </div>
</footer>
