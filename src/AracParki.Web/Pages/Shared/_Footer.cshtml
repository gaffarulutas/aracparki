          <li><a href="/ilanlar">Tüm ilanlar</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>Kurumsal</h3>
        <ul>
          <li><a href="@(page == "home" ? "#guven" : "/#guven")">Güven</a></li>
          <li><a href="@(page == "home" ? "#ilan-ver" : "/#ilan-ver")">İlan ver</a></li>
          <li><a href="@(page == "home" ? "#sehirler" : "/#sehirler")">Popüler iller</a></li>
