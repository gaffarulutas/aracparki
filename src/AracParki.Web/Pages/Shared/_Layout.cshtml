@using System.Text.Json
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.Extensions.Options
@using AracParki.Application.Email
@inject SiteUrls SiteUrls
@inject IAntiforgery Antiforgery
@inject IOptions<SeoSettings> SeoOptions
@{
    var pageKey = ViewData["PageKey"] as string ?? "home";
    var isAuth = pageKey == "auth";
    var requestPath = Context.Request.Path.Value ?? string.Empty;
    var needDetailGallery = ViewData["NeedDetailGallery"] is true
        || requestPath.StartsWith("/admin/ilanlar/", StringComparison.OrdinalIgnoreCase);
    var title = ViewData["Title"] as string ?? "Araç Parkı";
    var description = ViewData["Description"] as string
        ?? "Araç Parkı — Türkiye genelinde satılık, kiralık ve ikinci el iş makineleri.";
    var ogTitle = ViewData["OgTitle"] as string ?? title;
    var robots = ViewData["Robots"] as string ?? "index, follow, max-image-preview:large";
    var includeQueryInCanonical = ViewData["CanonicalIncludeQuery"] as bool? ?? false;
    var canonical = ViewData["CanonicalUrl"] as string
        ?? SiteUrls.CanonicalFromRequest(includeQueryInCanonical);
    var ogUrl = ViewData["OgUrl"] as string ?? canonical;
    var defaultOgImage = SiteUrls.Absolute(Url.Content("~/assets/hero/banner-1200.jpg"));
    var ogImage = ViewData["OgImage"] as string ?? defaultOgImage;
    if (!ogImage.StartsWith("http", StringComparison.OrdinalIgnoreCase))
    {
        ogImage = SiteUrls.Absolute(ogImage);
    }
    var ogImageAlt = ViewData["OgImageAlt"] as string ?? "Araç Parkı — iş makineleri";
    var ogType = ViewData["OgType"] as string ?? "website";
    var twitterCard = ViewData["TwitterCard"] as string ?? "summary_large_image";
    var cspNonce = Context.GetCspNonce();
    var jsonLdExtra = ViewData["JsonLd"] as string;
    var breadcrumbJsonLd = ViewData[Breadcrumbs.JsonLdViewDataKey] as string;
    var afTokens = Antiforgery.GetAndStoreTokens(Context);
    var seo = SeoOptions.Value;

    var websiteLd = new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "WebSite",
        ["name"] = "Araç Parkı",
        ["url"] = SiteUrls.Origin + "/",
        ["description"] = "Türkiye genelinde satılık, kiralık ve ikinci el iş makineleri.",
        ["inLanguage"] = "tr-TR",
        ["potentialAction"] = new Dictionary<string, object?>
        {
            ["@type"] = "SearchAction",
            ["target"] = SiteUrls.Origin + "/ilanlar?q={search_term_string}",
            ["query-input"] = "required name=search_term_string"
        }
    };

    var orgLd = new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "Organization",
        ["name"] = "Araç Parkı",
        ["url"] = SiteUrls.Origin + "/",
        ["logo"] = SiteUrls.Absolute("/assets/logo/icon-512.png"),
        ["description"] = "İş makineleri ilan platformu"
    };

    var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = null };
    var websiteJson = JsonSerializer.Serialize(websiteLd, jsonOpts);
    var orgJson = JsonSerializer.Serialize(orgLd, jsonOpts);
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@title</title>
    <meta name="description" content="@description" />
    <meta name="robots" content="@robots" />
    @if (!string.IsNullOrWhiteSpace(seo.GoogleSiteVerification))
    {
        <meta name="google-site-verification" content="@seo.GoogleSiteVerification" />
    }
    <meta name="theme-color" content="#ffe600" />
    <meta name="color-scheme" content="light" />
    <meta name="request-verification-token" content="@afTokens.RequestToken" />
    <link rel="canonical" href="@canonical" />

    <meta property="og:type" content="@ogType" />
    <meta property="og:locale" content="tr_TR" />
    <meta property="og:site_name" content="Araç Parkı" />
    <meta property="og:title" content="@ogTitle" />
    <meta property="og:description" content="@description" />
    <meta property="og:url" content="@ogUrl" />
    <meta property="og:image" content="@ogImage" />
    <meta property="og:image:secure_url" content="@ogImage" />
    @if (ViewData["OgImageType"] is string ogImageType)
    {
        <meta property="og:image:type" content="@ogImageType" />
    }
    <meta property="og:image:width" content="@(ViewData["OgImageWidth"] as string ?? "1200")" />
    <meta property="og:image:height" content="@(ViewData["OgImageHeight"] as string ?? "630")" />
    <meta property="og:image:alt" content="@ogImageAlt" />

    <meta name="twitter:card" content="@twitterCard" />
    <meta name="twitter:title" content="@ogTitle" />
    <meta name="twitter:description" content="@description" />
    <meta name="twitter:image" content="@ogImage" />
    <meta name="twitter:image:alt" content="@ogImageAlt" />

    <link rel="manifest" href="~/manifest.webmanifest" asp-append-version="true" />
    <link rel="icon" href="~/assets/logo/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="~/assets/logo/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="~/assets/logo/favicon-16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="~/assets/logo/apple-touch-icon.png" sizes="180x180" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700&family=Manrope:wght@400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/buttons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/icons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/header.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/footer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/badges.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/toastify/toastify.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tw-ui.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/styles.css" asp-append-version="true" />
    @if (pageKey is "home")
    {
        <link rel="stylesheet" href="~/css/components/hero.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/components/aside.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/pages/home.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/components/cards.css" asp-append-version="true" />
    }
    else if (pageKey is "list")
    {
        <link rel="stylesheet" href="~/css/components/breadcrumb.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/components/aside.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/components/cards.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/pages/list.css" asp-append-version="true" />
    }
    else if (pageKey is "detail")
    {
        <link rel="stylesheet" href="~/css/components/breadcrumb.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/components/cards.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/pages/detail.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/lib/lightgallery/lightgallery-bundle.min.css" asp-append-version="true" />
    }
    else if (pageKey is "auth")
    {
        <link rel="stylesheet" href="~/css/pages/auth.css" asp-append-version="true" />
    }
    else if (pageKey is "wizard")
    {
        <link rel="stylesheet" href="~/css/pages/ilan-ver.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/lib/quill/quill.snow.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/lib/cropperjs/cropper.min.css" asp-append-version="true" />
        @* Step 5 reuses detail gallery markup + lightGallery lightbox *@
        <link rel="stylesheet" href="~/css/pages/detail.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/lib/lightgallery/lightgallery-bundle.min.css" asp-append-version="true" />
    }
    else if (pageKey is "account")
    {
        <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/components/cards.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/components/badges.css" asp-append-version="true" />
        @if (needDetailGallery)
        {
            <link rel="stylesheet" href="~/css/pages/detail.css" asp-append-version="true" />
            <link rel="stylesheet" href="~/lib/lightgallery/lightgallery-bundle.min.css" asp-append-version="true" />
        }
        @if (ViewData["NeedCropper"] as bool? == true)
        {
            <link rel="stylesheet" href="~/lib/cropperjs/cropper.min.css" asp-append-version="true" />
        }
    }
    else if (pageKey is "dealer")
    {
        <link rel="stylesheet" href="~/css/components/breadcrumb.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/components/cards.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/pages/dealer.css" asp-append-version="true" />
    }
    else if (pageKey is "legal")
    {
        <link rel="stylesheet" href="~/css/components/breadcrumb.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/pages/legal.css" asp-append-version="true" />
    }

    @if (!string.IsNullOrEmpty(cspNonce))
    {
        <script type="application/ld+json" nonce="@cspNonce">@Html.Raw(websiteJson)</script>
        <script type="application/ld+json" nonce="@cspNonce">@Html.Raw(orgJson)</script>
        if (!string.IsNullOrWhiteSpace(jsonLdExtra))
        {
            <script type="application/ld+json" nonce="@cspNonce">@Html.Raw(jsonLdExtra)</script>
        }
        if (!string.IsNullOrWhiteSpace(breadcrumbJsonLd))
        {
            <script type="application/ld+json" nonce="@cspNonce">@Html.Raw(breadcrumbJsonLd)</script>
        }
        if (seo.HasGoogleAnalytics)
        {
            <script async src="https://www.googletagmanager.com/gtag/js?id=@seo.GoogleAnalyticsMeasurementId" nonce="@cspNonce"></script>
            <script nonce="@cspNonce">
              window.dataLayer = window.dataLayer || [];
              function gtag(){dataLayer.push(arguments);}
              gtag('js', new Date());
              gtag('config', '@seo.GoogleAnalyticsMeasurementId');
            </script>
        }
    }
</head>
<body data-page="@pageKey"
      data-authenticated="@(User.Identity?.IsAuthenticated == true ? "1" : "0")"
      x-data="siteChrome">
    <a class="skip-link" href="#main">İçeriğe geç</a>
    <div id="route-progress" class="route-progress" role="presentation" aria-hidden="true"></div>

    <div class="site-chrome">
        @if (!isAuth)
        {
            <partial name="Shared/_Header" model="pageKey" />
            @await RenderSectionAsync("CrumbBar", required: false)
        }

        <partial name="Shared/_EmailVerifyBanner" />
    </div>

    @RenderBody()

    <div class="toast" id="toast" hidden role="status" aria-live="polite"
         data-boot-toast="@(TempData["AuthNotice"] as string)"
         data-draft-toast="@(TempData["DraftNotice"] as string)"></div>

    @if (!isAuth)
    {
        <partial name="Shared/_Footer" model="pageKey" />
    }

    <script src="~/lib/htmx/htmx.min.js" asp-append-version="true" defer></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/lib/toastify/toastify.min.js" asp-append-version="true" defer></script>
    <script src="~/js/site.js" asp-append-version="true" defer></script>
    <script src="~/lib/alpine/focus.min.js" asp-append-version="true" defer></script>
    <script src="~/lib/alpine/alpine.min.js" asp-append-version="true" defer></script>
</body>
</html>
