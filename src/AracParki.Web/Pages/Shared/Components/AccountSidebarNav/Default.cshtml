@model AracParki.Application.Accounts.Dtos.AccountNavCountsDto
@{
    var path = ViewContext.HttpContext.Request.Path.Value ?? string.Empty;
    bool On(string prefix) => path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
    var isPanel = On("/panel");
    var isIlanlarim = On("/ilanlarim");
    var isFavorilerim = On("/favorilerim");
    var isKayitli = On("/kayitli-aramalar");
    var isMesajlarim = On("/mesajlarim");
    var isBildirimler = On("/bildirimler");
    var isBilgilerim = On("/bilgilerim") || On("/hesabim");
    var isKurumsal = On("/kurumsal-hesap");
    var isAyarlar = On("/ayarlar");
}
<div class="account-nav-panel">
  <div class="account-nav-brand">
    <span class="account-nav-brand-label">Hesabım</span>
  </div>

  <div class="account-nav-scroll">
    <div class="account-nav-section">
      <p class="account-nav-section-title">Özet</p>
      <ul class="account-nav-list" aria-label="Panel">
        <li>
          <partial name="Shared/Partials/_AccountNavItem" model='("/panel", "Panel", "layout-dashboard", isPanel, (int?)null)' />
        </li>
      </ul>
    </div>

    <div class="account-nav-section">
      <p class="account-nav-section-title">İlanlar</p>
      <ul class="account-nav-list" aria-label="İlan işlemleri">
        <li>
          <partial name="Shared/Partials/_AccountNavItem" model='("/ilanlarim", "İlanlarım", "list", isIlanlarim, (int?)Model.Listings)' />
        </li>
      </ul>
    </div>

    <div class="account-nav-section">
      <p class="account-nav-section-title">Takip</p>
      <ul class="account-nav-list" aria-label="Takip işlemleri">
        <li>
          <partial name="Shared/Partials/_AccountNavItem" model='("/favorilerim", "Favorilerim", "heart", isFavorilerim, (int?)Model.Favorites)' />
        </li>
        <li>
          <partial name="Shared/Partials/_AccountNavItem" model='("/kayitli-aramalar", "Kayıtlı aramalar", "bookmark", isKayitli, (int?)Model.SavedSearches)' />
        </li>
      </ul>
    </div>

    <div class="account-nav-section">
      <p class="account-nav-section-title">İletişim</p>
      <ul class="account-nav-list" aria-label="İletişim">
        <li>
          <partial name="Shared/Partials/_AccountNavItem" model='("/mesajlarim", "Mesajlarım", "message-circle", isMesajlarim, (int?)Model.UnreadMessages)' />
        </li>
        <li>
          <partial name="Shared/Partials/_AccountNavItem" model='("/bildirimler", "Bildirimler", "bell", isBildirimler, (int?)Model.UnreadNotifications)' />
        </li>
      </ul>
    </div>

    <div class="account-nav-section">
      <p class="account-nav-section-title">Hesap</p>
      <ul class="account-nav-list" aria-label="Hesap işlemleri">
        <li>
          <partial name="Shared/Partials/_AccountNavItem" model='("/bilgilerim", "Bilgilerim", "circle-user", isBilgilerim, (int?)null)' />
        </li>
        <li>
          <partial name="Shared/Partials/_AccountNavItem" model='("/kurumsal-hesap", "Kurumsal Hesap", "building-2", isKurumsal, (int?)null)' />
        </li>
        <li>
          <partial name="Shared/Partials/_AccountNavItem" model='("/ayarlar", "Ayarlar", "settings", isAyarlar, (int?)null)' />
        </li>
      </ul>
    </div>
  </div>

  <div class="account-nav-footer">
    <form method="post" action="/cikis" class="account-nav-logout">
      @Html.AntiForgeryToken()
      <button type="submit">
        <ap-icon name="log-out" size="18" class="ap-icon account-nav-ico" aria-hidden="true" />
        <span>Çıkış yap</span>
      </button>
    </form>
  </div>
</div>
