@using AracParki.Application.Listings.Dtos
@model IReadOnlyList<ListingCardDto>
@if (Model.Count == 0)
{
  <div class="empty-state">
    <p>Bu kriterlere uygun ilan yok.</p>
    <a class="btn btn-machine" href="/ilanlar">Tüm ilanları gör</a>
  </div>
}
else
{
  foreach (var item in Model)
  {
    <partial name="Shared/Partials/_ListingCard" model="item" />
  }
}
