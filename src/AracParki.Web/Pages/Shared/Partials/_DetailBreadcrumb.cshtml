@model AracParki.Web.Pages.Ilan.IndexModel
@{
    var listing = Model.Listing!;
    var intent = listing.PrimaryIntent switch
    {
        ListingIntent.Kiralik => ListingIntent.Kiralik,
        _ => ListingIntent.Satilik
    };
    var rootUrl = ListingRoutes.List;
    var intentUrl = ListingRoutes.ListUrl(new() { Intent = intent });
    var categoryUrl = ListingRoutes.ListUrl(new()
    {
        Intent = intent,
        CategoryId = listing.CategoryId > 0 ? listing.CategoryId : null,
        Category = listing.CategoryId > 0 ? null : listing.Category
    });
    var crumbSep = $"<span class=\"bc-sep\" aria-hidden=\"true\">{Lucide.Svg("chevron-right", "ap-icon bc-sep-icon", 12)}</span>";
}
<div id="site-crumb-bar" class="list-crumb-bar">
  <div class="list-crumb-inner">
    <nav class="list-crumb" aria-label="Sayfa yolu">
      <ol class="breadcrumb">
        <li>
          <a href="/">Anasayfa</a>
          @Html.Raw(crumbSep)
        </li>
        <li>
          <a href="@rootUrl">İş Makineleri</a>
          @Html.Raw(crumbSep)
        </li>
        <li>
          <a href="@intentUrl">@ListingIntent.Label(intent)</a>
          @Html.Raw(crumbSep)
        </li>
        <li>
          <a class="bc-truncate" href="@categoryUrl" title="@listing.Category">@listing.Category</a>
          @Html.Raw(crumbSep)
        </li>
        <li>
          <span class="bc-current bc-truncate" title="@listing.Title">@listing.Title</span>
        </li>
      </ol>
    </nav>
  </div>
</div>
