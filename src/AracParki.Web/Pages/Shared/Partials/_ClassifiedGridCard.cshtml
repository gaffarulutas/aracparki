@using System.Globalization
@using AracParki.Application.Listings.Dtos
@model ListingCardDto
@{
    var href = ListingRoutes.Detail(Model.AdNo);
    var tr = CultureInfo.GetCultureInfo("tr-TR");
    var priceText = Model.Price.ToString("N0", tr) + " TL";
    if (!string.IsNullOrWhiteSpace(Model.PriceUnit))
    {
        priceText += " / " + PriceUnit.Label(Model.PriceUnit);
    }
    var metaParts = new List<string> { Model.ModelYear.ToString(tr) };
    if (Model.Hours is not null)
    {
        metaParts.Add(Model.Hours.Value.ToString("N0", tr) + " saat");
    }
    metaParts.Add(Model.City);
}
<a class="classified-grid-card" href="@href">
  <span class="classified-grid-thumb">
    <img src="@Model.CoverImageUrl" alt="" loading="lazy" width="240" height="180" />
  </span>
  <span class="classified-grid-body">
    <span class="classified-grid-title">@Model.Title</span>
    <span class="classified-grid-price">@priceText</span>
    <span class="classified-grid-meta">@string.Join(" · ", metaParts)</span>
    @if (Model.IsVerified)
    {
      <span class="classified-badge classified-badge--verified">
        <ap-icon name="badge-check" size="12" class="ap-icon" aria-hidden="true" />
        Doğrulanmış
      </span>
    }
  </span>
</a>
