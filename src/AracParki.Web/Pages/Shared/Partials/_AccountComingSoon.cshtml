@model string
@{
    var message = string.IsNullOrWhiteSpace(Model)
        ? "Bu bölüm yakında kullanıma açılacak."
        : Model;
}
<div class="empty-state" role="status">
  <span class="empty-state-icon" aria-hidden="true"><ap-icon name="construction" size="24" class="ap-icon" /></span>
  <p>@message</p>
</div>
