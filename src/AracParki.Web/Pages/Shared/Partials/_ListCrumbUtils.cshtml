@using System.Security.Claims
@using AracParki.Application.Accounts.Services
@inject AccountNavCountsService NavCounts
@{
    var favorites = 0;
    var savedSearches = 0;
    if (User.Identity?.IsAuthenticated == true)
    {
        var raw = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (long.TryParse(raw, out var accountId) && accountId > 0)
        {
            var counts = await NavCounts.GetAsync(accountId, Context.RequestAborted);
            favorites = counts.Favorites;
            savedSearches = counts.SavedSearches;
        }
    }

    var favoritesLabel = favorites > 0 ? $"Favori İlanlarım ({favorites})" : "Favori İlanlarım";
    var searchesLabel = savedSearches > 0 ? $"Favori Aramalarım ({savedSearches})" : "Favori Aramalarım";

    var showCompare = ViewData["ShowCrumbCompare"] as bool? == true;
    var currentAdNo = ViewData["CompareCurrentAdNo"] as string ?? "";
    var currentTitle = ViewData["CompareCurrentTitle"] as string ?? "";
    var currentThumb = ViewData["CompareCurrentThumb"] as string ?? "";
    var currentPrice = ViewData["CompareCurrentPrice"] as string ?? "";
    var currentMeta = ViewData["CompareCurrentMeta"] as string ?? "";
}
<ul class="list-crumb-utils" aria-label="Hızlı bağlantılar">
  <li><a href="/favorilerim">@favoritesLabel</a></li>
  <li><a href="/kayitli-aramalar">@searchesLabel</a></li>
  @if (showCompare)
  {
    <li class="list-crumb-compare"
        x-data="listingCompareCrumb"
        data-compare-adno="@currentAdNo"
        data-compare-title="@currentTitle"
        data-compare-thumb="@currentThumb"
        data-compare-price="@currentPrice"
        data-compare-meta="@currentMeta"
        @@keydown.escape.window="close"
        @@click.outside="close">
      <button type="button"
              class="list-crumb-compare-trigger"
              x-ref="trigger"
              @@click="toggle"
              :aria-expanded="openAria"
              aria-haspopup="dialog"
              aria-controls="compare-popover">
        <span x-text="label">Karşılaştır</span>
      </button>
      <div id="compare-popover"
           class="list-crumb-compare-panel"
           role="dialog"
           aria-label="Karşılaştır"
           x-ref="panel"
           x-show="open"
           x-cloak>
        <div class="compare-pop-arrow" aria-hidden="true"></div>
        <div class="compare-pop-head">Karşılaştır</div>
        <div class="compare-pop-body">
          @* Sahibinden: detaydaysa ve listede değilse teklif kartı — kamera placeholder + Listeye Ekle *@
          <div class="compare-pop-card compare-pop-current" x-ref="currentOffer" hidden>
            <div class="compare-pop-current-media" aria-hidden="true">
              <span class="compare-pop-current-placeholder">
                <ap-icon name="camera" size="20" class="ap-icon" aria-hidden="true" />
              </span>
            </div>
            <div class="compare-pop-current-body">
              <p class="compare-pop-current-text">Görüntülemekte olduğunuz ilanı listeye eklemek ister misiniz?</p>
              <button type="button"
                      class="compare-pop-current-add"
                      x-ref="addBtn">
                Karşılaştırma Listesine Ekle
              </button>
            </div>
          </div>
          <div class="compare-pop-list" x-ref="list"></div>
          <p class="compare-pop-empty" x-ref="empty" hidden>Karşılaştırma listeniz boş.</p>
        </div>
        <div class="compare-pop-foot">
          <a class="compare-pop-go"
             href="/karsilastir"
             x-ref="goLink"
             @@click="goCompare">Karşılaştır</a>
        </div>
      </div>
    </li>
  }
</ul>
