@page
@using AracParki.Application.Listings.Queries
@using AracParki.Domain.Listings
@model IndexModel
@{
    var seeAll = ListingRoutes.ListUrl(Model.Filter);
}

<main id="main">
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-media" aria-hidden="true">
      <picture>
        <source
          type="image/webp"
          srcset="/assets/hero/banner-800.webp 800w,
                  /assets/hero/banner-1200.webp 1200w,
                  /assets/hero/banner-1600.webp 1600w,
                  /assets/hero/banner.webp 1920w"
          sizes="100vw" />
        <img
          src="/assets/hero/banner-1200.jpg"
          srcset="/assets/hero/banner-800.jpg 800w,
                  /assets/hero/banner-1200.jpg 1200w,
                  /assets/hero/banner-1600.jpg 1600w,
                  /assets/hero/banner.jpg 1920w"
          sizes="100vw"
          alt=""
          width="1920"
          height="730"
          fetchpriority="high"
          decoding="async" />
      </picture>
    </div>
    <div class="hero-veil" aria-hidden="true"></div>
    <div class="container hero-inner">
      <h1 class="hero-title" id="hero-title">Makineyi işe göre seç</h1>
      <p class="hero-lead">
        Satılık, kiralık veya ikinci el — tonaj, güç ve çalışma saatiyle Türkiye genelinde karşılaştır.
      </p>
    </div>
  </section>

  <div class="home container">
    <aside class="home-aside" id="kategoriler" aria-label="Kategori menüsü">
      <div class="aside-card">
        <h2 class="aside-title">İş Makineleri</h2>
        <ul class="aside-list" id="category-grid">
          @foreach (var cat in Model.Categories)
          {
            var href = ListingRoutes.HubUrl(ListingIntent.Satilik, cat.Slug);
            <li>
              <a href="@href">
                @Html.Raw(CategoryIcons.Svg(cat.IconKey))
                <span>@cat.Name</span>
                <span class="count">@Formatters.Count(cat.ListingCount)</span>
              </a>
            </li>
          }
        </ul>
      </div>

      <partial name="Shared/Partials/_AdSlot" />

      <div class="aside-card" id="sehirler">
        <h2 class="aside-title">Popüler İller</h2>
        <ul class="aside-cities" id="city-grid">
          @foreach (var city in Model.PopularCities)
          {
            var href = ListingRoutes.ListUrl(new ListingSearchQuery
            {
                Intent = ListingIntent.Satilik,
                CityIds = [city.Id]
            }, citySlug: city.Slug);
            <li>
              <a href="@href">
                <span>@city.Name</span>
                <span class="count">@Formatters.Count(city.ListingCount)</span>
              </a>
            </li>
          }
        </ul>
      </div>
    </aside>

    <div class="home-main">
      <section class="promo-strip" aria-labelledby="promo-title">
        <div class="promo-copy">
          <h2 class="promo-title" id="promo-title">İlanları daralt</h2>
          <p class="promo-lead">Satılık veya kiralık, kategori ve il seçerek doğru makineye ulaş.</p>
        </div>
        <form class="promo-filters" method="get" action="/ilanlar">
          <label class="sr-only" for="filter-intent">İlan tipi</label>
          <select id="filter-intent" name="tip" aria-label="İlan tipi seç">
            <option value="">Satılık / Kiralık</option>
            @if (Model.Filter.Intent == ListingIntent.Satilik)
            {
              <option value="@ListingIntent.Satilik" selected>Satılık</option>
            }
            else
            {
              <option value="@ListingIntent.Satilik">Satılık</option>
            }
            @if (Model.Filter.Intent == ListingIntent.Kiralik)
            {
              <option value="@ListingIntent.Kiralik" selected>Kiralık</option>
            }
            else
            {
              <option value="@ListingIntent.Kiralik">Kiralık</option>
            }
          </select>
          <label class="sr-only" for="filter-category">Kategori</label>
          <select id="filter-category" name="kategori" aria-label="Kategori seç">
            <option value="">Kategori</option>
            @foreach (var cat in Model.CategoryOptions)
            {
              if (Model.Filter.Category == cat.Name)
              {
                <option value="@cat.Name" selected>@cat.Name</option>
              }
              else
              {
                <option value="@cat.Name">@cat.Name</option>
              }
            }
          </select>
          <label class="sr-only" for="filter-city">İl</label>
          <select id="filter-city" name="il" aria-label="İl seç">
            <option value="">İl</option>
            @foreach (var city in Model.CityOptions)
            {
              if (Model.Filter.City == city.Name)
              {
                <option value="@city.Name" selected>@city.Name</option>
              }
              else
              {
                <option value="@city.Name">@city.Name</option>
              }
            }
          </select>
          <button class="btn btn-machine" type="submit">İlanları Göster</button>
        </form>
      </section>

      <section class="partner-banner" aria-labelledby="partner-title">
        <div class="partner-banner-copy">
          <h2 class="partner-banner-title" id="partner-title">Bayi ve çözüm ortaklığı</h2>
          <p class="partner-banner-lead">Onaylı mağaza, bayi rozeti ve niyetli alıcılara erişim. Stok veya çözümünüzü büyütün.</p>
        </div>
        <a class="btn btn-ghost partner-banner-cta" href="/bayi-ortakligi">Detaylı bilgi</a>
      </section>

      @{
        var tipAll = ListingIntent.All;
        var tipSale = ListingIntent.Satilik;
        var tipRent = ListingIntent.Kiralik;
        var activeTip = Model.Filter.Intent is ListingIntent.Satilik or ListingIntent.Kiralik
            ? Model.Filter.Intent
            : tipAll;
        var activeTabId = activeTip == tipSale
            ? "vitrin-tab-satilik"
            : activeTip == tipRent
                ? "vitrin-tab-kiralik"
                : "vitrin-tab-all";
        var seeAllAll = ListingRoutes.ListUrl(new ListingSearchQuery { Intent = tipAll });
        var seeAllSale = ListingRoutes.ListUrl(new ListingSearchQuery { Intent = tipSale });
        var seeAllRent = ListingRoutes.ListUrl(new ListingSearchQuery { Intent = tipRent });
      }
      <section class="vitrin-block" id="vitrin" aria-labelledby="vitrin-title" data-vitrin>
        <div class="vitrin-head">
          <h2 id="vitrin-title">
            Öne çıkan ilanlar
            <span class="result-count" data-vitrin-count aria-live="polite">(@Model.Featured.Count)</span>
          </h2>
          <div class="vitrin-head-actions">
            <div class="filter-chips">
              <div class="filter-chips-tabs" role="tablist" aria-label="İlan tipi" data-vitrin-tabs>
                <a class="chip"
                   role="tab"
                   id="vitrin-tab-all"
                   href="/?tip=@tipAll"
                   data-vitrin-intent="@tipAll"
                   data-see-all="@seeAllAll"
                   aria-controls="listing-grid"
                   aria-selected="@(activeTip == tipAll ? "true" : "false")"
                   tabindex="@(activeTip == tipAll ? "0" : "-1")">Tümü</a>
                <a class="chip"
                   role="tab"
                   id="vitrin-tab-satilik"
                   href="/?tip=@tipSale"
                   data-vitrin-intent="@tipSale"
                   data-see-all="@seeAllSale"
                   aria-controls="listing-grid"
                   aria-selected="@(activeTip == tipSale ? "true" : "false")"
                   tabindex="@(activeTip == tipSale ? "0" : "-1")">Satılık</a>
                <a class="chip"
                   role="tab"
                   id="vitrin-tab-kiralik"
                   href="/?tip=@tipRent"
                   data-vitrin-intent="@tipRent"
                   data-see-all="@seeAllRent"
                   aria-controls="listing-grid"
                   aria-selected="@(activeTip == tipRent ? "true" : "false")"
                   tabindex="@(activeTip == tipRent ? "0" : "-1")">Kiralık</a>
              </div>
              <a class="chip" href="/ilanlar?durum=@EquipmentCondition.Used">İkinci El</a>
            </div>
            <a class="text-link" href="@seeAll" data-vitrin-see-all>Tümünü gör</a>
          </div>
        </div>
        <div class="listing-grid"
             id="listing-grid"
             role="tabpanel"
             aria-labelledby="@activeTabId"
             data-vitrin-grid
             data-vitrin-intent="@activeTip">
          <partial name="Shared/Partials/_FeaturedGrid" model="Model.Featured" />
        </div>
      </section>

      <section class="proof-strip" id="guven" aria-label="Neden Araç Parkı">
        <a class="proof-item" href="/dogrulanmis-satici">
          <ap-icon name="badge-check" size="22" />
          <div class="proof-item-copy">
            <strong>Doğrulanmış satıcı</strong>
            <span>Onaylı kurumsal bayi</span>
          </div>
        </a>
        <a class="proof-item" href="/net-fiyat">
          <ap-icon name="banknote" size="22" />
          <div class="proof-item-copy">
            <strong>Net fiyat</strong>
            <span>Satılık ve birimli kiralık</span>
          </div>
        </a>
        <a class="proof-item" href="/turkiye-geneli">
          <ap-icon name="map-pin" size="22" />
          <div class="proof-item-copy">
            <strong>81 il</strong>
            <span>Yayın ve arama kapsamı</span>
          </div>
        </a>
      </section>

      <section class="seller-cta" id="ilan-ver">
        <div class="seller-cta-copy">
          <h2>Makineni hemen yayına al</h2>
          <p>Satılık veya kiralık — Türkiye’deki alıcılara ulaş.</p>
        </div>
        <a class="btn btn-cta btn-lg" href="/ilan-ver">Ücretsiz İlan Ver</a>
      </section>

      <section class="vitrin-block recent-block" id="son-bakilanlar" hidden aria-labelledby="recent-title">
        <div class="vitrin-head">
          <h2 id="recent-title">
            Son bakılan ilanlar
            <span class="result-count" data-recent-count hidden></span>
          </h2>
        </div>
        <div class="listing-grid listing-grid--recent" data-recent-grid aria-live="polite"></div>
      </section>
    </div>
  </div>
</main>