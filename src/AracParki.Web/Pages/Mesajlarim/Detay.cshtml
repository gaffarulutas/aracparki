@page "/mesajlarim/{threadId:long}"
@model AracParki.Web.Pages.Mesajlarim.DetayModel
@using AracParki.Application.Listings
@using AracParki.Domain.Listings
@{
    Layout = "Shared/_AccountLayout";
    var thread = Model.Thread!;
    var thumb = ListingImageUrlVariants.WithVariant(thread.CoverImageUrl, ListingImageVariants.Card);
    var priceUnit = thread.PrimaryIntent == ListingIntent.Kiralik ? thread.PriceUnit : null;
    var price = Formatters.Price(thread.Price, priceUnit, thread.Currency);
    var lastId = thread.Messages.Count > 0 ? thread.Messages[^1].Id : 0L;
}
<header class="page-account-head">
  <partial name="Shared/Partials/_AccountBack" model='("/mesajlarim", "Mesajlarım")' />
  <h1>@thread.CounterpartyName</h1>
  <p class="page-account-lead">@thread.AdNo · yazışma</p>
</header>

<article class="msg-context-card">
  <a class="msg-context-media" href="/ilan/@thread.AdNo">
    <img src="@thumb" alt="" width="120" height="90" loading="lazy" decoding="async" />
  </a>
  <div class="msg-context-body">
    <a class="msg-context-title" href="/ilan/@thread.AdNo">@thread.ListingTitle</a>
    <div class="msg-context-meta">
      <span>@thread.AdNo</span>
      <strong class="msg-context-price">@price</strong>
    </div>
    <a class="text-link" href="/ilan/@thread.AdNo">İlanı aç</a>
  </div>
</article>

<p class="msg-safety" role="note">
  Ödeme linki, IBAN veya şifre paylaşmayın. Görüşmeyi mümkün olduğunca platform üzerinden sürdürün.
  Sorun yaşarsan <a class="text-link" href="/ilan/@thread.AdNo">ilan sayfasından şikayet</a>
  veya <a class="text-link" href="/iletisim">iletişim</a> üzerinden bize yaz.
</p>

<div class="msg-chat"
     x-data="listingMessageThread"
     data-thread-id="@thread.Id"
     data-last-id="@lastId"
     data-poll-url="/mesajlarim/@thread.Id?handler=Messages">
  <div class="msg-chat-log" x-ref="log" role="log" aria-live="polite" aria-relevant="additions">
    @if (thread.Messages.Count == 0)
    {
      <p class="msg-chat-empty">Henüz mesaj yok. İlk mesajı sen yaz.</p>
    }
    @foreach (var msg in thread.Messages)
    {
      <div class="msg-bubble @(msg.IsMine ? "is-mine" : "is-theirs")" data-msg-id="@msg.Id">
        <p class="msg-bubble-text">@msg.Body</p>
        <time class="msg-bubble-time" datetime="@msg.CreatedAt.UtcDateTime.ToString("o")">
          @msg.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
        </time>
      </div>
    }
  </div>

  @if (!string.IsNullOrWhiteSpace(Model.FormError))
  {
    <p class="form-error" role="alert">@Model.FormError</p>
  }

  <form method="post" asp-page-handler="Send" class="msg-compose">
    @Html.AntiForgeryToken()
    <label class="sr-only" for="msg-body">Mesaj</label>
    <textarea id="msg-body"
              name="Body"
              class="msg-compose-input"
              rows="3"
              maxlength="2000"
              required
              placeholder="Mesajını yaz…">@Model.Body</textarea>
    <button type="submit" class="btn btn-machine">Gönder</button>
  </form>
</div>
