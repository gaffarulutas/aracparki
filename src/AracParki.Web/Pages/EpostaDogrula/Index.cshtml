@page "/eposta-dogrula"
@using AracParki.Web.Infrastructure
@using System.Security.Claims
@model AracParki.Web.Pages.EpostaDogrula.IndexModel

<main class="auth-page" id="main">
  <div class="auth-shell">
    <header class="auth-brand">
      <a class="logo" href="/" aria-label="Araç Parkı ana sayfa">
        <span class="logo-arac">Araç</span><span class="logo-parki">Parkı</span>
      </a>
    </header>

    <section class="auth-card" aria-labelledby="auth-title">
      @if (Model.Confirmed)
      {
        <div class="auth-success-icon" aria-hidden="true">
          <ap-icon name="circle-check" size="22" />
        </div>
        <h1 class="auth-title" id="auth-title">Hesabın onaylandı</h1>
        <p class="auth-lead">E-posta adresin doğrulandı. Artık ilan verebilir, favori ekleyebilirsin.</p>
        <a class="btn btn-machine btn-block auth-submit" href="/">Anasayfaya git</a>
        <p class="auth-switch"><a href="/ilanlar">İlanlara göz at</a></p>
      }
      else if (Model.PendingConfirm)
      {
        <h1 class="auth-title" id="auth-title">E-postanı onayla</h1>
        <p class="auth-lead">Hesabını etkinleştirmek için aşağıdaki butona tıkla.</p>
        <form method="post" asp-page-handler="Confirm" class="auth-form">
          <input type="hidden" name="Token" value="@Model.Token" />
          <button class="btn btn-machine btn-block auth-submit" type="submit">Hesabımı onayla</button>
        </form>
      }
      else if (Model.ResendSubmitted)
      {
        <h1 class="auth-title" id="auth-title">E-postanı kontrol et</h1>
        <p class="auth-lead">
          Onay bağlantısını hesabına bağlı adrese gönderdik.
          Spam klasörünü de kontrol et. Eski maillerdeki bağlantılar geçersiz olabilir.
        </p>
        <a class="btn btn-machine btn-block auth-submit" href="/">Anasayfaya dön</a>
      }
      else if (!string.IsNullOrEmpty(Model.FormError))
      {
        <h1 class="auth-title" id="auth-title">Bağlantı geçersiz</h1>
        <p class="auth-lead">@Model.FormError</p>
        @if (User.Identity?.IsAuthenticated == true && !AuthCookie.IsEmailConfirmed(User))
        {
          <form method="post" asp-page-handler="Resend" class="auth-form">
            <button class="btn btn-machine btn-block auth-submit" type="submit">Yeni onay maili gönder</button>
          </form>
        }
        else
        {
          <a class="btn btn-machine btn-block auth-submit" href="/giris">Giriş yap</a>
        }
      }
      else if (User.Identity?.IsAuthenticated == true && !AuthCookie.IsEmailConfirmed(User))
      {
        <h1 class="auth-title" id="auth-title">E-postanı onayla</h1>
        <p class="auth-lead">
          <strong>@User.FindFirst(ClaimTypes.Email)?.Value</strong>
          adresine onay maili gönderebilirsin — tekrar yazmana gerek yok.
        </p>
        <form method="post" asp-page-handler="Resend" class="auth-form">
          <button class="btn btn-machine btn-block auth-submit" type="submit">Onay maili gönder</button>
        </form>
        <p class="auth-switch"><a href="/">Şimdilik geç</a></p>
      }
    </section>
  </div>
</main>
