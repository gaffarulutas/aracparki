@page "/kurumsal-hesap"
@model AracParki.Web.Pages.KurumsalHesap.IndexModel
@using AracParki.Application.Listings
@using AracParki.Domain.Corporate
@{
    Layout = "Shared/_AccountLayout";
}
<header class="page-account-head">
  <partial name="Shared/Partials/_AccountBreadcrumb" />
  <div class="page-account-title-row">
    <div>
      <h1>Kurumsal Hesap</h1>
      <p class="page-account-lead">Bayi / galeri profillerini oluştur, evraklarını yükle ve onaya gönder. Onaylı kurumsal hesabınla ilan verebilirsin.</p>
    </div>
    <div class="page-account-actions">
      <a class="btn btn-machine btn-sm" href="/kurumsal-hesap/duzenle">+ Yeni</a>
    </div>
  </div>
</header>

@if (!string.IsNullOrWhiteSpace(Model.Notice))
{
  <p class="corp-notice" role="status">@Model.Notice</p>
}

@if (Model.Accounts.Count == 0)
{
  <div class="empty-state">
    <span class="empty-state-icon" aria-hidden="true"><ap-icon name="building-2" size="22" class="ap-icon" /></span>
    <p>Henüz kurumsal hesabın yok.</p>
    <p class="ap-hint">Kurumsal hesap oluşturup evraklarını yükledikten sonra admin onayıyla ilanlarını firma adına yayınlayabilirsin.</p>
    <div class="empty-state-actions">
      <a class="btn btn-machine" href="/kurumsal-hesap/duzenle">+ Yeni kurumsal hesap</a>
    </div>
  </div>
}
else
{
  <div class="corp-list">
    @foreach (var account in Model.Accounts)
    {
      var initial = string.IsNullOrWhiteSpace(account.DisplayName)
          ? "?"
          : char.ToUpperInvariant(account.DisplayName.Trim()[0]).ToString();
      <article class="corp-card">
        <div class="admin-corp-avatar @(string.IsNullOrWhiteSpace(account.LogoUrl) ? null : "has-logo")" aria-hidden="true">
          @if (!string.IsNullOrWhiteSpace(account.LogoUrl))
          {
            <img src="@ListingImageUrlVariants.WithVariant(account.LogoUrl, "thumb")"
                 alt=""
                 width="88"
                 height="88"
                 loading="lazy"
                 decoding="async" />
          }
          else
          {
            @initial
          }
        </div>
        <div class="corp-card-body">
          <div class="admin-corp-title-row">
            <h2 class="corp-card-title">
              <a href="/kurumsal-hesap/duzenle?id=@account.Id">@account.DisplayName</a>
            </h2>
            <span class="@CorporateStatus.BadgeClass(account.Status)">@CorporateStatus.Label(account.Status)</span>
          </div>
          <p class="corp-card-meta">
            @CompanyType.Label(account.CompanyType) · @account.TradeName
          </p>
          <p class="corp-card-meta">@account.CityName / @account.DistrictName · VKN/TCKN: @account.TaxNumber</p>
          @if (account.Status == CorporateStatus.Rejected && !string.IsNullOrWhiteSpace(account.RejectionReason))
          {
            <p class="corp-reject-note"><strong>Red nedeni:</strong> @account.RejectionReason</p>
          }
        </div>
        <a class="btn btn-ghost btn-sm" href="/kurumsal-hesap/duzenle?id=@account.Id">
          @(account.Status is CorporateStatus.Draft or CorporateStatus.Rejected ? "Düzenle" : "Görüntüle")
        </a>
      </article>
    }
  </div>
}
