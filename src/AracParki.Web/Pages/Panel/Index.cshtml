@page "/panel"
@model AracParki.Web.Pages.Panel.IndexModel
@{
    Layout = "Shared/_AccountLayout";
}
<header class="page-account-head">
  <h1>Panel</h1>
  <p class="page-account-lead">@(Model.Greeting)</p>
</header>

<div class="account-dash">
  <a class="account-dash-card" href="/ilanlarim">
    <span class="account-dash-icon" aria-hidden="true"><ap-icon name="list" size="22" class="ap-icon" /></span>
    <span class="account-dash-body">
      <span class="account-dash-title">İlanlarım</span>
      <span class="account-dash-meta">
        @(Model.ListingCount) yayında
        @if (Model.PendingCount > 0)
        {
          <text> · @Model.PendingCount incelemede</text>
        }
        @if (Model.RejectedCount > 0)
        {
          <text> · @Model.RejectedCount red</text>
        }
      </span>
    </span>
  </a>
  <a class="account-dash-card" href="/favorilerim">
    <span class="account-dash-icon" aria-hidden="true"><ap-icon name="heart" size="22" class="ap-icon" /></span>
    <span class="account-dash-body">
      <span class="account-dash-title">Favorilerim</span>
      <span class="account-dash-meta">Beğendiğin ilanlar</span>
    </span>
  </a>
  <a class="account-dash-card" href="/mesajlarim">
    <span class="account-dash-icon" aria-hidden="true"><ap-icon name="message-circle" size="22" class="ap-icon" /></span>
    <span class="account-dash-body">
      <span class="account-dash-title">Mesajlarım</span>
      <span class="account-dash-meta">Yazışmaların</span>
    </span>
  </a>
  <a class="account-dash-card" href="/bilgilerim">
    <span class="account-dash-icon" aria-hidden="true"><ap-icon name="circle-user" size="22" class="ap-icon" /></span>
    <span class="account-dash-body">
      <span class="account-dash-title">Bilgilerim</span>
      <span class="account-dash-meta">Ad, e-posta ve telefon</span>
    </span>
  </a>
  <a class="account-dash-card" href="/kurumsal-hesap">
    <span class="account-dash-icon" aria-hidden="true"><ap-icon name="building-2" size="22" class="ap-icon" /></span>
    <span class="account-dash-body">
      <span class="account-dash-title">Kurumsal Hesap</span>
      <span class="account-dash-meta">
        @if (Model.CorporateApprovedCount > 0)
        {
          <text>@Model.CorporateApprovedCount onaylı firma</text>
          @if (Model.CorporatePendingCount > 0)
          {
            <text> · @Model.CorporatePendingCount incelemede</text>
          }
        }
        else if (Model.CorporatePendingCount > 0)
        {
          <text>@Model.CorporatePendingCount başvuru incelemede</text>
        }
        else
        {
          <text>Bayi / galeri profili oluştur</text>
        }
      </span>
    </span>
  </a>
  <a class="account-dash-card" href="/ayarlar">
    <span class="account-dash-icon" aria-hidden="true"><ap-icon name="settings" size="22" class="ap-icon" /></span>
    <span class="account-dash-body">
      <span class="account-dash-title">Ayarlar</span>
      <span class="account-dash-meta">Hesap tercihleri</span>
    </span>
  </a>
</div>
