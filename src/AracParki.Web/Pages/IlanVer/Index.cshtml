@page "/ilan-ver"
@model AracParki.Web.Pages.IlanVer.IndexModel
@{
    var draft = Model.Draft;
    var step = Model.Step;
    var neighborhoodsJson = Model.AttrJson(
        Model.Neighborhoods.Select(n => new { id = n.Id, name = n.DisplayName }));
    var initialDistrictsJson = Model.AttrJson(
        Model.Districts.Select(d => new { id = d.Id, name = d.Name }));
    var corporatePhonesJson = Model.AttrJson(
        Model.ApprovedCorporateAccounts.Select(c => new { id = c.Id, phone = c.Phone, name = c.DisplayName }));
}
@if (Model.ShowPhoneGate)
{
    @await Html.PartialAsync("Shared/_PhoneVerifyModal", Model)
}
else if (Model.ShowDraftResumeModal)
{
    @await Html.PartialAsync("Shared/_DraftResumeModal", Model)
}
<main id="main" class="container wizard-page @(Model.ShowDraftResumeModal ? "is-gated" : null)">
  @{
    var stepMeta = new (string Short, string Full)[]
    {
      ("Kategori", "Tip ve kategori"),
      ("Araç", "Teknik bilgiler"),
      ("Fiyat", "Fiyat ve konum"),
      ("Foto", "Fotoğraflar"),
      ("Yayın", "Kontrol ve yayın")
    };
  }

  <header class="wizard-hero">
    <div class="wizard-hero-copy">
      <p class="wizard-kicker">Ücretsiz ilan</p>
      <h1 class="wizard-title">Makine ilanı oluştur</h1>
      <p class="wizard-subtitle">Birkaç adımda profesyonel bir ilan hazırla. Taslağın otomatik kaydedilir.</p>
      @if (draft.IsMeaningful && !Model.ShowDraftResumeModal)
      {
        <p class="wizard-draft-chip" role="status">
          <ap-icon name="check" size="14" aria-hidden="true" />
          <span>Taslak kaydedildi · Adım @Math.Clamp(draft.Step is >= 1 and <= 5 ? draft.Step : step, 1, 5)</span>
        </p>
      }
    </div>
    <ol class="wizard-stepper" aria-label="İlan adımları">
      @for (var i = 1; i <= 5; i++)
      {
        var isCurrent = i == step;
        var isComplete = IndexModel.IsStepComplete(i, draft, Model.RequirePhoneVerification);
        var canAccess = IndexModel.CanAccessStep(i, draft, Model.RequirePhoneVerification);
        var state = isCurrent ? "is-current" : isComplete ? "is-done" : "is-todo";
        var clickable = canAccess && !isCurrent && !Model.ShowPhoneGate && !Model.ShowDraftResumeModal;
        <li>
          @if (clickable)
          {
            <a class="wizard-stepper-item @state is-clickable"
               href="/ilan-ver?adim=@i"
               aria-label="@stepMeta[i - 1].Full adımına git">
              <span class="wizard-stepper-index" aria-hidden="true">
                <ap-icon name="check" size="14" />
              </span>
              <span class="wizard-stepper-text">
                <span class="wizard-stepper-label">@stepMeta[i - 1].Short</span>
                <span class="wizard-stepper-desc">@stepMeta[i - 1].Full</span>
              </span>
            </a>
          }
          else
          {
            <div class="wizard-stepper-item @state"
                 @(isCurrent ? Html.Raw("aria-current=\"step\"") : null)>
              <span class="wizard-stepper-index" aria-hidden="true">
                @if (isComplete && !isCurrent)
                {
                  <ap-icon name="check" size="14" />
                }
                else
                {
                  @i
                }
              </span>
              <span class="wizard-stepper-text">
                <span class="wizard-stepper-label">@stepMeta[i - 1].Short</span>
                <span class="wizard-stepper-desc">@stepMeta[i - 1].Full</span>
              </span>
            </div>
          }
        </li>
      }
    </ol>
  </header>

  @if (!string.IsNullOrWhiteSpace(Model.FormError))
  {
    <div class="wizard-alert" role="alert">
      <ap-icon name="circle-alert" size="18" aria-hidden="true" />
      <div>
        <strong>Devam etmek için düzeltmen gereken yerler var</strong>
        <p>@Model.FormError</p>
        @if (Model.FieldErrors.Count > 0)
        {
          <ul class="wizard-alert-list">
            @foreach (var (key, msg) in Model.FieldErrors)
            {
              var anchor = key.StartsWith("spec:", StringComparison.Ordinal)
                ? "field-" + key["spec:".Length..]
                : "field-" + key;
              <li><a href="#@anchor">@msg</a></li>
            }
          </ul>
        }
        else if (Model.FormErrors.Count > 1)
        {
          <ul class="wizard-alert-list">
            @foreach (var err in Model.FormErrors)
            {
              <li>@err</li>
            }
          </ul>
        }
      </div>
    </div>
  }

  <section class="wizard-card @(step == 1 ? "wizard-card--cascade" : null)" aria-labelledby="wizard-step-heading">
      <div class="wizard-card-head">
        <h2 class="wizard-card-title" id="wizard-step-heading">@Model.StepTitle</h2>
      </div>

      @* ── Step 1: Cascade ─────────────────────────────────────────── *@
      @if (step == 1)
      {
        <p class="wizard-lead">İlan tipi → durum → grup → kategori → marka → model → yıl yolunu izle.</p>
        <form method="post" asp-page-handler="Cascade" class="wizard-cascade"
              id="wizard-form"
              x-data="ilanVerCascader"
              data-groups='@Model.AttrJson(Model.CategoryGroups.Select(g => new {
                  id = g.Id,
                  name = g.Name,
                  categories = g.Categories.Select(c => new {
                      id = c.Id,
                      name = c.Name,
                      capacityMetric = c.CapacityMetric
                  })
              }))'
              data-intent="@draft.PrimaryIntent"
              data-condition="@draft.Condition"
              data-group-id="@draft.GroupId"
              data-category-id="@draft.CategoryId"
              data-brand-id="@draft.BrandId"
              data-model-id="@(draft.ModelId ?? 0)"
              data-model-name="@draft.ModelName"
              data-model-year="@draft.ModelYear"
              data-group-name="@draft.GroupName"
              data-category-name="@draft.CategoryName"
              data-brand-name="@draft.BrandName">
          @Html.AntiForgeryToken()
          <input type="hidden" name="intent" :value="intent" />
          <input type="hidden" name="condition" :value="condition" />
          <input type="hidden" name="groupId" :value="groupId" />
          <input type="hidden" name="groupName" :value="groupName" />
          <input type="hidden" name="categoryId" :value="categoryId" />
          <input type="hidden" name="brandId" :value="brandId" />
          <input type="hidden" name="modelId" :value="modelId" />
          <input type="hidden" name="modelName" :value="modelName" />
          <input type="hidden" name="modelYear" :value="modelYear" />

          <div class="cascade-path" x-show="hasPath" x-cloak>
            <p class="cascade-path-text" x-text="pathText"></p>
            <button type="button" class="cascade-edit" @@click="reset">Düzenle</button>
          </div>

          <div class="cascade-board" role="group" aria-label="Kategori seçici">
            <div class="cascade-col">
              <p class="cascade-col-title">İlan tipi</p>
              <ul class="cascade-list" role="listbox" aria-label="İlan tipi">
                <template x-for="t in intentsView" :key="t.id">
                  <li>
                    <button type="button"
                            class="cascade-item"
                            :class="t.itemClass"
                            role="option"
                            :aria-selected="t.ariaSelected"
                            :data-id="t.id"
                            @@click="pickIntent">
                      <span x-text="t.name"></span>
                      <span class="cascade-chevron" aria-hidden="true">›</span>
                    </button>
                  </li>
                </template>
              </ul>
            </div>

            <div class="cascade-col" x-show="hasIntent" x-cloak>
              <p class="cascade-col-title">Durum</p>
              <ul class="cascade-list" role="listbox" aria-label="Araç durumu">
                <template x-for="c in conditionsView" :key="c.id">
                  <li>
                    <button type="button"
                            class="cascade-item"
                            :class="c.itemClass"
                            role="option"
                            :aria-selected="c.ariaSelected"
                            :data-id="c.id"
                            @@click="pickCondition">
                      <span x-text="c.name"></span>
                      <span class="cascade-chevron" aria-hidden="true">›</span>
                    </button>
                  </li>
                </template>
              </ul>
            </div>

            <div class="cascade-col" x-show="hasCondition" x-cloak>
              <p class="cascade-col-title">Grup</p>
              <ul class="cascade-list" role="listbox" aria-label="Grup">
                <template x-for="g in groupsView" :key="g.id">
                  <li>
                    <button type="button"
                            class="cascade-item"
                            :class="g.itemClass"
                            role="option"
                            :aria-selected="g.ariaSelected"
                            :data-id="g.id"
                            @@click="pickGroup">
                      <span x-text="g.name"></span>
                      <span class="cascade-chevron" aria-hidden="true">›</span>
                    </button>
                  </li>
                </template>
              </ul>
            </div>

            <div class="cascade-col" x-show="hasGroup" x-cloak>
              <p class="cascade-col-title">Kategori</p>
              <ul class="cascade-list" role="listbox" aria-label="Kategori">
                <template x-for="c in categoriesView" :key="c.id">
                  <li>
                    <button type="button"
                            class="cascade-item"
                            :class="c.itemClass"
                            role="option"
                            :aria-selected="c.ariaSelected"
                            :data-id="c.id"
                            @@click="pickCategory">
                      <span x-text="c.name"></span>
                      <span class="cascade-chevron" aria-hidden="true">›</span>
                    </button>
                  </li>
                </template>
              </ul>
            </div>

            <div class="cascade-col" x-show="hasCategory" x-cloak :class="brandsColClass" :aria-busy="brandsBusy">
              <p class="cascade-col-title">Marka</p>
              <ul class="cascade-list" role="listbox" aria-label="Marka">
                <li class="cascade-empty cascade-loading" x-show="brandsLoading" x-cloak>
                  <span class="cascade-spinner" aria-hidden="true"></span>
                  <span>Markalar yükleniyor…</span>
                </li>
                <li class="cascade-empty" x-show="brandsEmpty" x-cloak>Marka bulunamadı</li>
                <template x-for="b in brandsView" :key="b.id">
                  <li x-show="brandsReady">
                    <button type="button"
                            class="cascade-item"
                            :class="b.itemClass"
                            role="option"
                            :aria-selected="b.ariaSelected"
                            :data-id="b.id"
                            @@click="pickBrand">
                      <span x-text="b.name"></span>
                      <span class="cascade-chevron" aria-hidden="true">›</span>
                    </button>
                  </li>
                </template>
              </ul>
            </div>

            <div class="cascade-col" x-show="hasBrand" x-cloak :class="modelsColClass" :aria-busy="modelsBusy">
              <p class="cascade-col-title">Model</p>
              <ul class="cascade-list" role="listbox" aria-label="Model">
                <li class="cascade-empty cascade-loading" x-show="modelsLoading" x-cloak>
                  <span class="cascade-spinner" aria-hidden="true"></span>
                  <span>Modeller yükleniyor…</span>
                </li>
                <li class="cascade-empty" x-show="modelsEmpty" x-cloak>Model bulunamadı — “Listede yok” ile devam edebilirsin</li>
                <template x-for="m in modelsView" :key="m.id">
                  <li x-show="modelsReady">
                    <button type="button"
                            class="cascade-item"
                            :class="m.itemClass"
                            role="option"
                            :aria-selected="m.ariaSelected"
                            :data-id="m.id"
                            @@click="pickModel">
                      <span x-text="m.name"></span>
                      <span class="cascade-chevron" aria-hidden="true">›</span>
                    </button>
                  </li>
                </template>
                <li x-show="modelsReady">
                  <button type="button"
                          class="cascade-item"
                          :class="customModelClass"
                          role="option"
                          @@click="selectCustomModel">
                    <span>Listede yok / diğer</span>
                    <span class="cascade-chevron" aria-hidden="true">›</span>
                  </button>
                </li>
              </ul>
            </div>

            <div class="cascade-col" x-show="canPickYear" x-cloak>
              <p class="cascade-col-title">Yıl</p>
              <ul class="cascade-list" role="listbox" aria-label="Model yılı">
                <template x-for="y in yearsView" :key="y.id">
                  <li>
                    <button type="button"
                            class="cascade-item"
                            :class="y.itemClass"
                            role="option"
                            :aria-selected="y.ariaSelected"
                            :data-id="y.id"
                            @@click="pickYear">
                      <span x-text="y.label"></span>
                    </button>
                  </li>
                </template>
              </ul>
            </div>
          </div>

          @* Custom model adı — scroll konteynerinin DIŞINDA: odak kaydırmayla çakışmaz *@
          <div class="cascade-custom" x-show="showCustomModel" x-cloak>
            <label class="cascade-custom-label" for="cascade-model-custom">
              Model adı <abbr class="field-req" title="Zorunlu">*</abbr>
            </label>
            @* CSP-friendly Alpine, x-model'in ürettiği atama ifadesini çalıştıramıyor;
               onun yerine tek yönlü :value + @input ile bağlıyoruz. *@
            <input id="cascade-model-custom" type="text" maxlength="120" required
                   placeholder="Örn. 320D, R936, PC210…"
                   autocomplete="off"
                   :value="modelName"
                   @@input="onCustomModelInput" />
            <p class="cascade-custom-hint">
              <span x-show="customModelNeedsName" x-cloak>Model adını yaz, ardından yukarıdaki listeden <strong>yıl</strong> seç.</span>
              <span x-show="customModelHasName" x-cloak>Şimdi yukarıdan <strong>yıl</strong> seç.</span>
            </p>
          </div>

          <div class="wizard-actions cascade-actions wizard-actions--inline">
            <span class="wizard-actions-hint">İlan tipi, durum ve kategoriyi seçerek başla</span>
            <button class="btn btn-machine" type="submit" :disabled="cannotContinue">
              Kaydet ve devam →
            </button>
          </div>
        </form>
      }

      @* ── Step 2: Machine ─────────────────────────────────────────── *@
      else if (step == 2)
      {
        <p class="wizard-lead">
          <strong>
            @ListingIntent.Label(draft.PrimaryIntent)
            @if (EquipmentCondition.Known.Contains(draft.Condition))
            {
              <span> · @EquipmentCondition.Label(draft.Condition)</span>
            }
            ·
            @(string.Join(" › ", new[] { draft.GroupName, draft.CategoryName, draft.BrandName, draft.ModelName }
              .Where(s => !string.IsNullOrWhiteSpace(s))))
            @if (draft.ModelYear > 0)
            {
              <span> · @draft.ModelYear</span>
            }
          </strong>
          — araç ve teknik detayları tamamla.
          <a class="wizard-inline-link" href="/ilan-ver?adim=1">Kategoriyi değiştir</a>
        </p>
        <form method="post" asp-page-handler="Machine" class="wizard-form" id="wizard-form"
              x-data="ilanVerMachine"
              data-hours-unknown="@(draft.HoursUnknown ? "true" : "false")"
              novalidate>
          @Html.AntiForgeryToken()

          @* Durum cascader’da seçilir *@
          <input type="hidden" name="condition" value="@draft.Condition" />
          @* Beygir / tonaj katalogdan gelir — kullanıcıya gösterme *@
          <input type="hidden" name="tons" value="@(draft.Tons > 0 ? draft.Tons.ToString(System.Globalization.CultureInfo.InvariantCulture) : "0")" />
          @if (draft is { HorsepowerFromCatalog: true, Horsepower: >= 0 })
          {
            <input type="hidden" name="horsepower" value="@draft.Horsepower" />
          }
          else
          {
            <input type="hidden" name="horsepowerUnknown" value="true" />
          }
          @if (draft.CapacityMetric == "capacity_kg" && draft is { CapacityKgFromCatalog: true, CapacityKg: > 0 })
          {
            <input type="hidden" name="capacityKg" value="@draft.CapacityKg" />
          }

          <section class="wizard-section" aria-labelledby="wizard-usage-heading">
            <h3 class="wizard-section-title" id="wizard-usage-heading">Kullanım bilgisi</h3>
            <div class="form-grid-2">
              <div class="form-row @Model.FieldInvalidClass("hours")" id="field-hours">
                <label for="hours">
                  Çalışma saati <abbr class="field-req" title="Zorunlu">*</abbr>
                </label>
                <div class="wizard-input-group"
                     :class="hoursUnknown ? 'is-unknown' : null">
                  <input id="hours" name="hours" type="number" min="0"
                         value="@(draft.Hours is >= 0 ? draft.Hours.Value.ToString() : null)"
                         :disabled="hoursUnknown"
                         :required="hoursRequired"
                         aria-invalid="@(Model.AriaInvalid("hours"))"
                         aria-describedby="hint-hours@(Model.HasFieldError("hours") ? " err-hours" : "")" />
                  <label class="wizard-input-group-addon">
                    <input type="checkbox" name="hoursUnknown" value="true"
                           :checked="hoursUnknown"
                           @@change="toggleHoursUnknown" />
                    <span>Bilmiyorum</span>
                  </label>
                </div>
                <p class="field-hint" id="hint-hours">Saat bilmiyorsan “Bilmiyorum”u işaretle.</p>
                @if (Model.HasFieldError("hours"))
                {
                  <p class="field-error" id="err-hours" role="alert">@Model.FieldError("hours")</p>
                }
              </div>

              @if (draft.CapacityMetric == "capacity_kg" && !draft.CapacityKgFromCatalog)
              {
                <div class="form-row @Model.FieldInvalidClass("capacityKg")" id="field-capacityKg">
                  <label for="capacityKg">
                    Kapasite (kg) <abbr class="field-req" title="Zorunlu">*</abbr>
                  </label>
                  <input id="capacityKg" name="capacityKg" type="number" required min="1"
                         value="@(draft.CapacityKg is > 0 ? draft.CapacityKg.Value.ToString() : null)"
                         aria-invalid="@(Model.AriaInvalid("capacityKg"))"
                         aria-describedby="@(Model.HasFieldError("capacityKg") ? "err-capacityKg" : null)" />
                  @if (Model.HasFieldError("capacityKg"))
                  {
                    <p class="field-error" id="err-capacityKg" role="alert">@Model.FieldError("capacityKg")</p>
                  }
                </div>
              }

              <div class="form-row">
                <label for="serialNo">Seri numarası <span class="field-optional">(isteğe bağlı)</span></label>
                <input id="serialNo" name="serialNo" type="text" maxlength="80"
                       value="@draft.SerialNo" placeholder="Örn. ABC-12345" />
              </div>
            </div>
          </section>

          @if (Model.Attachments.Count > 0)
          {
            <section class="wizard-section" aria-labelledby="wizard-attachments-heading">
              <div class="wizard-section-head">
                <h3 class="wizard-section-title" id="wizard-attachments-heading">Donanım ve ekipman</h3>
                <p class="wizard-section-hint">Araçta bulunan ekleri seç. Birden fazla seçebilirsin.</p>
              </div>
              <div class="ap-tile-group ap-tile-group--6" role="group" aria-labelledby="wizard-attachments-heading">
                @foreach (var att in Model.Attachments)
                {
                  <label class="ap-tile">
                    <input type="checkbox" name="attachmentIds" value="@att.Id"
                           @(Model.HasAttachment(att.Id) ? "checked" : null) />
                    <span class="ap-tile-face">
                      <span class="ap-tile-mark" aria-hidden="true"></span>
                      <span>@att.Name</span>
                    </span>
                  </label>
                }
              </div>
            </section>
          }

          @if (Model.Attributes.Count > 0)
          {
            var visibleSpecCount = 0;
            foreach (var attr in Model.Attributes)
            {
              if (draft.HorsepowerFromCatalog && attr.Key == "engine_power_hp") { continue; }
              var catalogVal = draft.Specs.TryGetValue(attr.Key, out var cv) ? cv : "";
              var locked = draft.CatalogLocked && !string.IsNullOrWhiteSpace(catalogVal)
                           && attr.Key is "lift_height_m" or "working_height_m" or "platform_height_m"
                               or "payload_t" or "max_lift_capacity_t" or "capacity_t"
                               or "capacity_kg" or "lift_capacity_kg" or "rated_operating_capacity_kg"
                               or "boom_length_m" or "vertical_reach_m" or "drum_volume_m3"
                               or "capacity_m3h" or "plant_capacity_m3h" or "engine_power_hp";
              if (!locked) { visibleSpecCount++; }
            }

            @foreach (var attr in Model.Attributes)
            {
              if (draft.HorsepowerFromCatalog && attr.Key == "engine_power_hp")
              {
                continue;
              }
              var key = $"specs[{attr.Key}]";
              var val = draft.Specs.TryGetValue(attr.Key, out var s) ? s : "";
              var fromCatalog = draft.CatalogLocked && !string.IsNullOrWhiteSpace(val)
                                && attr.Key is "lift_height_m" or "working_height_m" or "platform_height_m"
                                    or "payload_t" or "max_lift_capacity_t" or "capacity_t"
                                    or "capacity_kg" or "lift_capacity_kg" or "rated_operating_capacity_kg"
                                    or "boom_length_m" or "vertical_reach_m" or "drum_volume_m3"
                                    or "capacity_m3h" or "plant_capacity_m3h" or "engine_power_hp";
              if (fromCatalog)
              {
                <input type="hidden" name="@key" value="@val" />
              }
            }

            @if (visibleSpecCount > 0)
            {
              <section class="wizard-section" aria-labelledby="wizard-specs-heading">
                <div class="wizard-section-head">
                  <h3 class="wizard-section-title" id="wizard-specs-heading">Teknik özellikler</h3>
                  <p class="wizard-section-hint">Motor, şanzıman ve diğer teknik detaylar.</p>
                </div>
                <div class="ap-stack wizard-spec-stack">
                  @foreach (var attr in Model.Attributes)
                  {
                    if (draft.HorsepowerFromCatalog && attr.Key == "engine_power_hp")
                    {
                      continue;
                    }
                    var key = $"specs[{attr.Key}]";
                    var fieldId = $"spec-{attr.Key}";
                    var labelId = $"spec-label-{attr.Key}";
                    var val = draft.Specs.TryGetValue(attr.Key, out var s) ? s : "";
                    var opts = Model.EnumOptions(attr);
                    var fromCatalog = draft.CatalogLocked && !string.IsNullOrWhiteSpace(val)
                                      && attr.Key is "lift_height_m" or "working_height_m" or "platform_height_m"
                                          or "payload_t" or "max_lift_capacity_t" or "capacity_t"
                                          or "capacity_kg" or "lift_capacity_kg" or "rated_operating_capacity_kg"
                                          or "boom_length_m" or "vertical_reach_m" or "drum_volume_m3"
                                          or "capacity_m3h" or "plant_capacity_m3h" or "engine_power_hp";
                    if (fromCatalog)
                    {
                      continue;
                    }
                    var specErrKey = "spec:" + attr.Key;
                    var fieldInvalid = Model.FieldInvalidClass(specErrKey);
                    <div class="ap-field @fieldInvalid" id="field-@attr.Key">
                      <label class="ap-label" id="@labelId" for="@fieldId">
                        @attr.Label@(attr.Unit is not null ? $" ({attr.Unit})" : null)
                        @if (attr.IsRequired)
                        {
                          <abbr class="field-req" title="Zorunlu">*</abbr>
                        }
                        else
                        {
                          <span class="field-optional">(isteğe bağlı)</span>
                        }
                      </label>
                      @if (opts.Count > 0)
                      {
                        <select id="@fieldId" name="@key" class="ap-input @Model.FieldInvalidClass(specErrKey)"
                                required="@(attr.IsRequired ? "required" : null)"
                                aria-invalid="@(Model.AriaInvalid(specErrKey))"
                                aria-describedby="@(Model.HasFieldError(specErrKey) ? $"err-{attr.Key}" : null)">
                          <option value="" selected="@(string.IsNullOrEmpty(val) ? "selected" : null)">
                            @(attr.IsRequired ? "Seçin" : "Belirtilmedi")
                          </option>
                          @foreach (var opt in opts)
                          {
                            var optLabel = SpecOptionLabels.For(opt);
                            <option value="@opt" selected="@(val == opt ? "selected" : null)">@optLabel</option>
                          }
                        </select>
                      }
                      else if (attr.DataType == "bool")
                      {
                        var isTrue = val is "true" or "1";
                        var isFalse = val is "false" or "0";
                        <select id="@fieldId" name="@key" class="ap-input @Model.FieldInvalidClass(specErrKey)"
                                required="@(attr.IsRequired ? "required" : null)"
                                aria-invalid="@(Model.AriaInvalid(specErrKey))"
                                aria-describedby="@(Model.HasFieldError(specErrKey) ? $"err-{attr.Key}" : null)">
                          <option value="" selected="@(!isTrue && !isFalse ? "selected" : null)">
                            @(attr.IsRequired ? "Seçin" : "Belirtilmedi")
                          </option>
                          <option value="true" selected="@(isTrue ? "selected" : null)">Evet</option>
                          <option value="false" selected="@(isFalse ? "selected" : null)">Hayır</option>
                        </select>
                      }
                      else
                      {
                        <input id="@fieldId" name="@key" class="ap-input @Model.FieldInvalidClass(specErrKey)"
                               type="@(attr.DataType == "number" ? "number" : "text")"
                               step="any" value="@val" aria-labelledby="@labelId"
                               required="@(attr.IsRequired ? "required" : null)"
                               aria-invalid="@(Model.AriaInvalid(specErrKey))"
                               aria-describedby="@(Model.HasFieldError(specErrKey) ? $"err-{attr.Key}" : null)" />
                      }
                      @if (Model.HasFieldError(specErrKey))
                      {
                        <p class="field-error" id="err-@attr.Key" role="alert">@Model.FieldError(specErrKey)</p>
                      }
                    </div>
                  }
                </div>
              </section>
            }
          }

          <section class="wizard-section" aria-labelledby="wizard-copy-heading">
            <div class="wizard-section-head">
              <h3 class="wizard-section-title" id="wizard-copy-heading">İlan metni</h3>
              <p class="wizard-section-hint">Alıcının ilk gördüğü başlık ve açıklama.</p>
            </div>

            <div class="form-row @Model.FieldInvalidClass("title")" id="field-title">
              <label for="title">
                İlan başlığı <abbr class="field-req" title="Zorunlu">*</abbr>
              </label>
              <input id="title" name="title" type="text" required maxlength="200" value="@draft.Title"
                     placeholder="@draft.SuggestedTitle()"
                     aria-required="true"
                     aria-invalid="@(Model.AriaInvalid("title"))"
                     aria-describedby="hint-title@(Model.HasFieldError("title") ? " err-title" : "")" />
              <p class="field-hint" id="hint-title">Öneri: @draft.SuggestedTitle()</p>
              @if (Model.HasFieldError("title"))
              {
                <p class="field-error" id="err-title" role="alert">@Model.FieldError("title")</p>
              }
            </div>

            <div class="form-row @Model.FieldInvalidClass("description")" id="field-description"
                 x-data="ilanVerCharCount"
                 data-max="@ListingDescriptionHtml.MaxLength"
                 data-quill-description>
              <label id="label-description" for="description-editor">
                Açıklama <abbr class="field-req" title="Zorunlu">*</abbr>
              </label>
              <input type="hidden" id="description" name="description" required
                     value="@draft.Description"
                     x-ref="input"
                     aria-required="true"
                     aria-invalid="@(Model.AriaInvalid("description"))"
                     aria-describedby="hint-description@(Model.HasFieldError("description") ? " err-description" : "")" />
              <div id="description-editor"
                   class="wizard-quill"
                   data-quill-editor
                   data-placeholder="Bakım geçmişi, ekipman, konum notları…"
                   role="textbox"
                   aria-multiline="true"
                   aria-labelledby="label-description"
                   aria-required="true"
                   aria-invalid="@(Model.AriaInvalid("description"))"
                   aria-describedby="hint-description@(Model.HasFieldError("description") ? " err-description" : "")"
                   tabindex="0"></div>
              <div class="wizard-char-count">
                <p class="field-hint" id="hint-description">Kalın, liste ve bağlantı ile net yaz. Dürüst açıklamalar daha hızlı dönüş getirir.</p>
                <p class="wizard-char-count-value" aria-live="polite">
                  <span x-text="count">@ListingDescriptionHtml.ToPlainText(draft.Description).Length</span> / <span x-text="max">@ListingDescriptionHtml.MaxLength</span>
                </p>
              </div>
              @if (Model.HasFieldError("description"))
              {
                <p class="field-error" id="err-description" role="alert">@Model.FieldError("description")</p>
              }
            </div>
          </section>

          <div class="wizard-actions wizard-actions--inline">
            <a class="btn btn-ghost" href="/ilan-ver?adim=1">← Geri</a>
            <button class="btn btn-machine" type="submit">Kaydet ve devam</button>
          </div>
        </form>
      }

      @* ── Step 3: Sale ────────────────────────────────────────────── *@
      else if (step == 3)
      {
        var isRent = draft.PrimaryIntent == ListingIntent.Kiralik;

        <p class="wizard-lead">
          <strong>@ListingIntent.Label(draft.PrimaryIntent)</strong>
          ilanı için fiyat ve konum bilgilerini gir.
        </p>
        <form method="post" asp-page-handler="Sale" class="wizard-form" id="wizard-form"
              x-data="ilanVerSale"
              data-city-id="@draft.CityId"
              data-district-id="@draft.DistrictId"
              data-neighborhood-id="@(draft.NeighborhoodId ?? 0)"
              data-districts="@initialDistrictsJson"
              data-neighborhoods="@neighborhoodsJson"
              data-price="@(draft.Price > 0 ? draft.Price.ToString("0", System.Globalization.CultureInfo.InvariantCulture) : "0")"
              data-currency="@Currency.Normalize(draft.Currency)"
              data-account-phone="@(Model.AccountPhone ?? "")"
              data-corporate-phones="@corporatePhonesJson"
              data-corporate-id="@(draft.CorporateAccountId?.ToString() ?? "")"
              data-contact-phone-source="@(string.IsNullOrWhiteSpace(draft.ContactPhoneSource) ? "account" : draft.ContactPhoneSource)"
              novalidate>
          @Html.AntiForgeryToken()

          <div class="wizard-section-grid">
          <section class="wizard-section" aria-labelledby="wizard-price-heading">
            <div class="wizard-section-head">
              <h3 class="wizard-section-title" id="wizard-price-heading">Fiyat</h3>
              <p class="wizard-section-hint">@(isRent ? "Kira bedeli ve birimi." : "Satış fiyatı ve para birimi.")</p>
            </div>
            <div class="ap-field @Model.FieldInvalidClass("price")" id="field-price">
              <label class="ap-label" for="price-display">
                @(isRent ? "Kira bedeli" : "Satış fiyatı")
                <abbr class="field-req" title="Zorunlu">*</abbr>
              </label>
              <div class="wizard-price-row">
                <input class="ap-input wizard-price-amount @Model.FieldInvalidClass("price")"
                       id="price-display"
                       type="text"
                       inputmode="numeric"
                       autocomplete="off"
                       placeholder="Örn. 1.250.000"
                       required
                       x-ref="priceDisplay"
                       aria-required="true"
                       aria-invalid="@(Model.AriaInvalid("price"))"
                       aria-describedby="@(Model.HasFieldError("price") ? "err-price" : "price-hint")"
                       @@input="onPriceInput"
                       @@blur="onPriceBlur" />
                <input type="hidden" name="price" x-ref="priceRaw" value="@(draft.Price > 0 ? draft.Price.ToString("0", System.Globalization.CultureInfo.InvariantCulture) : "")" />
                <label class="sr-only" for="currency">Para birimi</label>
                <select class="ap-input wizard-price-currency @Model.FieldInvalidClass("currency")"
                        id="currency"
                        name="currency"
                        x-ref="currency"
                        required
                        aria-invalid="@(Model.AriaInvalid("currency"))"
                        aria-describedby="@(Model.HasFieldError("currency") ? "err-currency" : null)"
                        @@change="onCurrencyChange">
                  @{
                    var selectedCurrency = Currency.Normalize(draft.Currency);
                    foreach (var code in new[] { Currency.Try, Currency.Usd, Currency.Eur })
                    {
                      if (selectedCurrency == code)
                      {
                        <option value="@code" selected>@Currency.Label(code)</option>
                      }
                      else
                      {
                        <option value="@code">@Currency.Label(code)</option>
                      }
                    }
                  }
                </select>
              </div>
              <p class="ap-hint" id="price-hint" x-show="hasPriceHint" x-text="priceHint" x-cloak></p>
              @if (Model.HasFieldError("price"))
              {
                <p class="field-error" id="err-price" role="alert">@Model.FieldError("price")</p>
              }
              @if (Model.HasFieldError("currency"))
              {
                <p class="field-error" id="err-currency" role="alert">@Model.FieldError("currency")</p>
              }
            </div>

            @if (isRent)
            {
              <div class="ap-field @Model.FieldInvalidClass("priceUnit")" id="field-priceUnit">
                <span class="ap-label" id="priceUnit-label">
                  Kira birimi <abbr class="field-req" title="Zorunlu">*</abbr>
                </span>
                <div class="ap-tile-group" role="radiogroup" aria-labelledby="priceUnit-label"
                     aria-required="true"
                     aria-invalid="@(Model.AriaInvalid("priceUnit"))"
                     aria-describedby="@(Model.HasFieldError("priceUnit") ? "err-priceUnit" : null)">
                  @foreach (var unit in new[] { PriceUnit.Day, PriceUnit.Week, PriceUnit.Month, PriceUnit.Hour })
                  {
                    <label class="ap-tile">
                      <input type="radio" name="priceUnit" value="@unit" required
                             @(draft.PriceUnit == unit ? "checked" : null) />
                      <span class="ap-tile-face">
                        <span class="ap-tile-mark" aria-hidden="true"></span>
                        <span>@PriceUnit.Label(unit)</span>
                      </span>
                    </label>
                  }
                </div>
                @if (Model.HasFieldError("priceUnit"))
                {
                  <p class="field-error" id="err-priceUnit" role="alert">@Model.FieldError("priceUnit")</p>
                }
              </div>
              <div class="ap-field">
                <span class="ap-label" id="operator-label">Operatör <span class="field-optional">(isteğe bağlı)</span></span>
                <div class="ap-tile-group ap-tile-group--bool" role="group" aria-labelledby="operator-label">
                  <label class="ap-tile">
                    <input type="checkbox" name="includesOperator" value="true"
                           @(draft.IncludesOperator ? "checked" : null) />
                    <span class="ap-tile-face">
                      <span class="ap-tile-mark" aria-hidden="true"></span>
                      <span>Operatör dahil</span>
                    </span>
                  </label>
                </div>
              </div>
            }
          </section>

          <section class="wizard-section @Model.FieldInvalidClass("sellerType")" id="field-sellerType" aria-labelledby="wizard-seller-heading">
            <div class="wizard-section-head">
              <h3 class="wizard-section-title" id="wizard-seller-heading">
                İlan sahibi <abbr class="field-req" title="Zorunlu">*</abbr>
              </h3>
              <p class="wizard-section-hint">
                @(Model.ApprovedCorporateAccounts.Count > 0
                    ? "Sahibinden veya onaylı kurumsal hesaplarından birini seç."
                    : "Satış veya kirayı kim yapıyor?")
              </p>
            </div>
            <div class="ap-tile-group @(Model.ApprovedCorporateAccounts.Count > 0 ? null : "ap-tile-group--2")"
                 role="radiogroup" aria-labelledby="wizard-seller-heading"
                 aria-required="true"
                 aria-invalid="@(Model.AriaInvalid("sellerType"))"
                 aria-describedby="@(Model.HasFieldError("sellerType") ? "err-sellerType" : "sellerType-hint")">
              <label class="ap-tile">
                <input type="radio" name="corporateAccountId" value="" required
                       @@change="onSellerChange"
                       @(draft.CorporateAccountId is > 0 ? null : "checked") />
                <span class="ap-tile-face">
                  <span class="ap-tile-mark" aria-hidden="true"></span>
                  <span>
                    Sahibinden
                    @if (!string.IsNullOrWhiteSpace(Model.OwnerDisplayName))
                    {
                      <span class="ap-hint">(@Model.OwnerDisplayName)</span>
                    }
                  </span>
                </span>
              </label>
              @foreach (var corp in Model.ApprovedCorporateAccounts)
              {
                <label class="ap-tile">
                  <input type="radio" name="corporateAccountId" value="@corp.Id" required
                         @@change="onSellerChange"
                         @(draft.CorporateAccountId == corp.Id ? "checked" : null) />
                  <span class="ap-tile-face">
                    <span class="ap-tile-mark" aria-hidden="true"></span>
                    <span>
                      @corp.DisplayName
                      <span class="ap-hint">(@CompanyType.Label(corp.CompanyType) · Bayi)</span>
                    </span>
                  </span>
                </label>
              }
            </div>
            @if (Model.ApprovedCorporateAccounts.Count == 0)
            {
              <p class="ap-hint" id="sellerType-hint">
                Bayi olarak ilan vermek için
                <a href="/kurumsal-hesap">kurumsal hesap oluştur</a>
                ve admin onayını bekle.
              </p>
            }
            @if (Model.HasFieldError("sellerType"))
            {
              <p class="field-error" id="err-sellerType" role="alert">@Model.FieldError("sellerType")</p>
            }
          </section>
          </div>

          <div class="wizard-section-grid">
          <section class="wizard-section" aria-labelledby="wizard-location-heading">
            <div class="wizard-section-head">
              <h3 class="wizard-section-title" id="wizard-location-heading">Konum</h3>
              <p class="wizard-section-hint">İlanın görüneceği il ve ilçe.</p>
            </div>
            <div class="ap-grid-2">
              <div class="ap-field @Model.FieldInvalidClass("cityId")" id="field-cityId">
                <label class="ap-label" for="cityId">
                  İl <abbr class="field-req" title="Zorunlu">*</abbr>
                </label>
                <select class="ap-input @Model.FieldInvalidClass("cityId")"
                        id="cityId"
                        name="cityId"
                        required
                        autocomplete="address-level1"
                        x-ref="city"
                        aria-invalid="@(Model.AriaInvalid("cityId"))"
                        aria-describedby="@(Model.HasFieldError("cityId") ? "err-cityId" : null)">
                  <option value="">İl seç</option>
                  @foreach (var c in Model.Cities)
                  {
                    if (draft.CityId == c.Id)
                    {
                      <option value="@c.Id" selected>@c.Name</option>
                    }
                    else
                    {
                      <option value="@c.Id">@c.Name</option>
                    }
                  }
                </select>
                @if (Model.HasFieldError("cityId"))
                {
                  <p class="field-error" id="err-cityId" role="alert">@Model.FieldError("cityId")</p>
                }
              </div>
              <div class="ap-field @Model.FieldInvalidClass("districtId")" id="field-districtId">
                <label class="ap-label" for="districtId">
                  İlçe <abbr class="field-req" title="Zorunlu">*</abbr>
                </label>
                <select class="ap-input @Model.FieldInvalidClass("districtId")"
                        id="districtId"
                        name="districtId"
                        required
                        autocomplete="address-level2"
                        x-ref="district"
                        disabled
                        aria-invalid="@(Model.AriaInvalid("districtId"))"
                        aria-describedby="@(Model.HasFieldError("districtId") ? "err-districtId" : null)">
                  <option value="">Önce il seç</option>
                </select>
                @if (Model.HasFieldError("districtId"))
                {
                  <p class="field-error" id="err-districtId" role="alert">@Model.FieldError("districtId")</p>
                }
              </div>
            </div>

            <div class="ap-field">
              <label class="ap-label" for="neighborhoodId">
                Mahalle
                <span class="ap-optional">isteğe bağlı</span>
              </label>
              <select class="ap-input"
                      id="neighborhoodId"
                      name="neighborhoodId"
                      autocomplete="address-level3"
                      x-ref="neighborhood"
                      disabled>
                <option value="">Önce ilçe seç</option>
              </select>
            </div>

            <p class="ap-hint" x-show="hasLocationStatus" x-text="locationStatus" x-cloak role="status" aria-live="polite"></p>
          </section>

          <section class="wizard-section @(Model.HasFieldError("phone") ? "is-invalid" : null)" id="field-phone" aria-labelledby="wizard-contact-heading">
            <h3 class="wizard-section-title" id="wizard-contact-heading">İletişim</h3>
            <p class="wizard-section-hint">İlanda görünecek telefon numarası.</p>
            <input type="hidden" name="contactPhoneSource" x-ref="contactPhoneSource"
                   value="@(string.IsNullOrWhiteSpace(draft.ContactPhoneSource) ? "account" : draft.ContactPhoneSource)" />

            <div class="ap-tile-group" role="radiogroup" aria-labelledby="wizard-contact-heading"
                 x-show="showPhoneChoices" x-cloak>
              <label class="ap-tile">
                <input type="radio" name="contactPhoneSourceUi" value="account"
                       @@change="onContactPhoneSourceChange"
                       :checked="isAccountPhoneSelected" />
                <span class="ap-tile-face">
                  <span class="ap-tile-mark" aria-hidden="true"></span>
                  <span>
                    Hesap telefonum
                    <span class="ap-hint" x-text="accountPhoneLabel"></span>
                  </span>
                </span>
              </label>
              <label class="ap-tile">
                <input type="radio" name="contactPhoneSourceUi" value="corporate"
                       @@change="onContactPhoneSourceChange"
                       :checked="isCorporatePhoneSelected" />
                <span class="ap-tile-face">
                  <span class="ap-tile-mark" aria-hidden="true"></span>
                  <span>
                    Bayi telefonu
                    <span class="ap-hint" x-text="corporatePhoneLabel"></span>
                  </span>
                </span>
              </label>
            </div>

            <div class="wizard-contact" x-show="showSinglePhone" x-cloak>
              <div class="wizard-contact-icon" aria-hidden="true">
                <ap-icon name="phone" size="18" />
              </div>
              <div>
                <p class="wizard-contact-label">İlanda görünecek telefon</p>
                <p class="wizard-contact-value" x-text="activePhoneLabel"></p>
                <p class="ap-hint">Alıcılar bu numaradan seni arayabilir.</p>
              </div>
            </div>

            <p class="ap-hint" x-show="showPhoneFallback" x-cloak>Yayınlamadan önce telefon doğrulaması istenecek.</p>

            @if (Model.HasFieldError("phone"))
            {
              <p class="field-error" id="err-phone" role="alert">@Model.FieldError("phone")</p>
            }
          </section>
          </div>

          <div class="ap-actions wizard-actions--inline">
            <a class="btn btn-ghost" href="/ilan-ver?adim=2">← Geri</a>
            <button class="btn btn-machine" type="submit">Kaydet ve devam</button>
          </div>
        </form>
      }

      @* ── Step 4: Images ──────────────────────────────────────────── *@
      else if (step == 4)
      {
        <p class="wizard-lead">Net, aydınlık fotoğraflar ilanı daha hızlı sonuçlandırır. Her görsel kare olarak kırpılır — ilk görsel kapak olur. En az 1 fotoğraf ekle.</p>

        <div class="wizard-uploader"
             id="wizard-uploader"
             x-data="ilanVerUploader"
             data-upload-url="@Url.Page("/IlanVer/Index", "UploadJson")"
             data-max-count="@ListingImageUrl.MaxCount"
             data-max-bytes="@ListingImageUrl.MaxUploadBytes"
             data-current-count="@draft.ImageUrls.Count"
             :aria-busy="busyAria">
          @Html.AntiForgeryToken()
          <div class="wizard-dropzone wizard-dropzone--lg"
               :class="dropzoneClass"
               @@dragenter.prevent="onDragEnter"
               @@dragover.prevent="onDragOver"
               @@dragleave.prevent="onDragLeave"
               @@drop.prevent="onDrop">
            <input class="sr-only"
                   id="file-upload"
                   type="file"
                   accept="image/jpeg,image/png,image/webp,image/heic,image/heif"
                   multiple
                   x-ref="file"
                   @@change="onFileChange" />
            <label for="file-upload" class="wizard-dropzone-face">
              <span class="wizard-dropzone-icon" aria-hidden="true">
                <ap-icon name="plus" size="32" />
              </span>
              <span class="wizard-dropzone-title">Fotoğrafları buraya bırak veya seç</span>
              <span class="wizard-dropzone-hint">JPG, PNG, WebP, HEIC · kare kırpma · dosya başına maks. 10 MB · en fazla @ListingImageUrl.MaxCount görsel</span>
              <span class="btn btn-ghost btn-sm wizard-dropzone-btn">Dosya seç</span>
            </label>
          </div>

          <div class="wizard-gallery" aria-label="Yüklenen fotoğraflar" x-ref="gallery">
            @for (var i = 0; i < draft.ImageUrls.Count; i++)
            {
              var url = draft.ImageUrls[i];
              <figure class="wizard-gallery-item @(i == 0 ? "is-cover" : null)" data-url="@url">
                <img src="@url" alt="" loading="lazy" width="480" height="480" />
                <figcaption>@(i == 0 ? "Kapak" : (i + 1).ToString())</figcaption>
                <div class="wizard-gallery-actions">
                  @if (i > 0)
                  {
                    <form method="post" asp-page-handler="SetCover">
                      @Html.AntiForgeryToken()
                      <input type="hidden" name="url" value="@url" />
                      <button type="submit" class="wizard-gallery-action">Kapak yap</button>
                    </form>
                  }
                  <form method="post" asp-page-handler="RemoveImage">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="url" value="@url" />
                    <button type="submit" class="wizard-gallery-action wizard-gallery-action--danger">Kaldır</button>
                  </form>
                </div>
              </figure>
            }

            <template x-for="item in queue" :key="item.id">
              <figure class="wizard-gallery-item is-uploading"
                      :data-state="item.state"
                      x-show="item.isVisible"
                      x-cloak>
                <img :src="item.previewUrl" alt="" width="480" height="480" />
                <div class="wizard-gallery-overlay"
                     x-show="item.showProgress"
                     role="status"
                     aria-live="polite">
                  <span class="wizard-gallery-spinner" aria-hidden="true"></span>
                  <div class="wizard-gallery-progress" role="progressbar"
                       :aria-valuenow="item.progress"
                       aria-valuemin="0"
                       aria-valuemax="100"
                       :aria-label="item.progressLabel">
                    <span class="wizard-gallery-progress-fill" :style="item.barStyle"></span>
                  </div>
                  <span class="wizard-gallery-progress-label" x-text="item.progressLabel"></span>
                </div>
                <div class="wizard-gallery-overlay is-error" x-show="item.showError">
                  <p class="wizard-gallery-error" x-text="item.error"></p>
                  <div class="wizard-gallery-overlay-actions">
                    <button type="button" class="btn btn-ghost btn-sm" @@click="item.retry">Tekrar dene</button>
                    <button type="button" class="link-quiet" @@click="item.dismiss">Kaldır</button>
                  </div>
                </div>
              </figure>
            </template>
          </div>

          <div class="wizard-crop-modal"
               id="wizard-crop-modal"
               x-show="cropOpen"
               x-cloak
               role="dialog"
               aria-modal="true"
               aria-labelledby="wizard-crop-title"
               @@keydown.escape.window="cancelCrop">
            <div class="wizard-crop-backdrop" @@click="cancelCrop"></div>
            <div class="wizard-crop-panel" tabindex="-1">
              <header class="wizard-crop-head">
                <h2 id="wizard-crop-title">Kare kırp</h2>
                <p class="wizard-crop-lead" x-text="cropFileName"></p>
              </header>
              <div class="wizard-crop-stage">
                <img x-ref="cropImage" alt="Kırpılacak görsel" />
              </div>
              <p class="wizard-crop-hint" x-show="cropError" x-text="cropError" role="alert"></p>
              <div class="wizard-crop-toolbar">
                <button type="button" class="btn btn-ghost btn-sm" @@click="rotateCropLeft" :disabled="cropBusy">90° sola</button>
                <button type="button" class="btn btn-ghost btn-sm" @@click="rotateCropRight" :disabled="cropBusy">90° sağa</button>
                <button type="button" class="btn btn-ghost btn-sm" @@click="resetCrop" :disabled="cropBusy">Sıfırla</button>
              </div>
              <div class="wizard-crop-actions">
                <button type="button" class="btn btn-ghost" @@click="cancelCrop" :disabled="cropBusy">Vazgeç</button>
                <button type="button" class="btn btn-ghost" @@click="uploadWithoutCrop" :disabled="cropBusy" x-show="cropError">Kırpmadan yükle</button>
                <button type="button" class="btn btn-machine" @@click="confirmCrop" :disabled="cropBusy">
                  <span x-text="cropSubmitLabel">Kırp ve yükle</span>
                </button>
              </div>
            </div>
          </div>
        </div>

        <form method="post" asp-page-handler="Images" class="wizard-form" id="wizard-form">
          @Html.AntiForgeryToken()
          <div id="wizard-hidden-urls">
            @foreach (var url in draft.ImageUrls)
            {
              <input type="hidden" name="imageUrls" value="@url" />
            }
          </div>
          <div class="wizard-actions wizard-actions--inline">
            <a class="btn btn-ghost" href="/ilan-ver?adim=3">← Geri</a>
            <button class="btn btn-machine" type="submit" id="wizard-images-continue"
                    @(draft.ImageUrls.Count == 0 ? "disabled" : null)>Kaydet ve devam</button>
          </div>
        </form>
      }

      @* ── Step 5: Preview ─────────────────────────────────────────── *@
      else
      {
        <p class="wizard-lead">Son kontrol. Her şey doğruysa yayınla — taslağın zaten kayıtlı.</p>
        <article class="wizard-preview">
          @if (draft.ImageUrls.Count > 0)
          {
            <img class="wizard-preview-cover" src="@draft.ImageUrls[0]" alt="" />
            @if (draft.ImageUrls.Count > 1)
            {
              <div class="wizard-thumb-grid wizard-preview-thumbs">
                @foreach (var url in draft.ImageUrls.Skip(1))
                {
                  <img class="wizard-thumb" src="@url" alt="" loading="lazy" />
                }
              </div>
            }
          }
          <div class="wizard-preview-body">
            <p class="wizard-preview-meta">
              @ListingIntent.Label(draft.PrimaryIntent)
              · @(draft.CorporateAccountId is > 0
                  ? (draft.CorporateName ?? "Bayi")
                  : SellerType.Label(draft.SellerType))
              · @draft.CategoryName
              · @draft.CityName / @draft.DistrictName
              @if (!string.IsNullOrWhiteSpace(draft.NeighborhoodName))
              {
                <span>/ @draft.NeighborhoodName</span>
              }
            </p>
            <h2 class="wizard-preview-title">@draft.Title</h2>
            <p class="wizard-preview-price">
              @Formatters.Price(draft.Price, draft.PriceUnit, draft.Currency)
            </p>
            <p class="wizard-preview-specs">
              @draft.BrandName @draft.ModelName · @draft.ModelYear
              @if (draft.Tons > 0)
              {
                <span> · @draft.Tons.ToString("0.##")t</span>
              }
              ·
              @if (draft.HoursUnknown || draft.Hours is null)
              {
                <span>Saat: Belirtilmedi</span>
              }
              else
              {
                <span>@draft.Hours.Value.ToString("N0") saat</span>
              }
              @if (draft is { HorsepowerFromCatalog: true, Horsepower: > 0 })
              {
                <span> · @draft.Horsepower.Value HP</span>
              }
              · @EquipmentCondition.Label(draft.Condition)
            </p>
            @if (!string.IsNullOrWhiteSpace(draft.SerialNo))
            {
              <p class="wizard-preview-serial">Seri No: @draft.SerialNo</p>
            }
            <div class="wizard-preview-desc detail-desc">@Html.Raw(ListingDescriptionHtml.ToSafeDisplayHtml(draft.Description))</div>
            <p class="wizard-muted">
              Görsel: @draft.ImageUrls.Count
              · Telefon: @(string.IsNullOrWhiteSpace(draft.Phone) ? Model.AccountPhone : draft.Phone)
              @if (draft.CorporateAccountId is > 0)
              {
                <span>· @(draft.ContactPhoneSource == "corporate" ? "Bayi hattı" : "Hesap hattı")</span>
              }
              @if (draft.AttachmentIds.Count > 0)
              {
                <span>· Ekipman: @draft.AttachmentIds.Count</span>
              }
              @if (draft.IncludesOperator)
              {
                <span>· Operatör dahil</span>
              }
            </p>
          </div>
        </article>

        <div class="wizard-publish-bar wizard-actions--inline">
          <a class="btn btn-ghost btn-lg" href="/">Taslağı sakla</a>
          <form method="post" asp-page-handler="Publish" class="wizard-publish-form" id="wizard-publish-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="publishToken" value="@Model.PublishToken" />
            <a class="link-quiet" href="/ilan-ver?adim=4">← Fotoğrafları düzenle</a>
            <button class="btn btn-cta btn-lg" type="submit">Yayınla</button>
          </form>
        </div>
        <p class="wizard-warn">Taslak hesabına kaydedilir. Sayfadan çıksan da kaldığın yerden devam edebilirsin.</p>
      }
    </section>
</main>

@section Scripts {
  @if (step == 2)
  {
    <script src="~/lib/quill/quill.js" asp-append-version="true" defer></script>
  }
  @if (step == 4)
  {
    <script src="~/lib/cropperjs/cropper.min.js" asp-append-version="true" defer></script>
  }
}
